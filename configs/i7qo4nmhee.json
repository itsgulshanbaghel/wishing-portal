{"html":"<!DOCTYPE html>\n<html lang=\"en\"><head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes, viewport-fit=cover\">\n  <title>✨ Your Magical Surprise · Greeter.com</title>\n  \n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&amp;family=Poppins:wght@300;400;500;600;700&amp;family=Great+Vibes&amp;display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\">\n  \n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n\n    :root {\n      --pink-start: #ff758c;\n      --pink-end: #ff7eb3;\n      --rose-gold: #e6a4b4;\n      --soft-peach: #ffd6c9;\n      --warm-blush: #ffc2d1;\n      --glow-pink: rgba(255, 182, 193, 0.5);\n      --bg-dark-1: #1a0f14;\n      --bg-dark-2: #2b1620;\n      --bg-dark-3: #000000;\n      --glass-bg: rgba(255, 255, 255, 0.06);\n      --glass-border: rgba(255, 255, 255, 0.12);\n    }\n\n    body {\n      font-family: 'Poppins', sans-serif;\n      background: linear-gradient(145deg, var(--bg-dark-1) 0%, var(--bg-dark-2) 70%, var(--bg-dark-3) 100%);\n      color: #fff0f3;\n      min-height: 100vh;\n      overflow-x: hidden;\n      scroll-behavior: smooth;\n    }\n\n    /* floating hearts background */\n    .floating-bg {\n      position: fixed;\n      inset: 0;\n      pointer-events: none;\n      z-index: 1;\n      overflow: hidden;\n    }\n\n    .floating-heart {\n      position: absolute;\n      color: rgba(255, 192, 203, 0.5);\n      font-size: 1.6rem;\n      animation: floatHeart 16s infinite ease-in-out;\n      filter: drop-shadow(0 0 12px #ffb6c1);\n      user-select: none;\n    }\n\n    @keyframes floatHeart {\n      0% { transform: translateY(110vh) rotate(0deg); opacity: 0; }\n      10% { opacity: 0.7; }\n      90% { opacity: 0.5; }\n      100% { transform: translateY(-20vh) rotate(20deg); opacity: 0; }\n    }\n\n    /* content above floating elements */\n    .content {\n      position: relative;\n      z-index: 10;\n    }\n\n    section {\n      min-height: 100vh;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      padding: 4rem 1.5rem;\n      text-align: center;\n    }\n\n    /* glassmorphism card */\n    .glass-card {\n      background: var(--glass-bg);\n      backdrop-filter: blur(18px);\n      -webkit-backdrop-filter: blur(18px);\n      border: 1px solid var(--glass-border);\n      border-radius: 48px;\n      padding: 2.5rem 2rem;\n      box-shadow: 0 25px 45px -10px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,182,193,0.1), 0 0 45px var(--glow-pink);\n      max-width: 950px;\n      width: 100%;\n      transition: transform 0.3s ease;\n    }\n\n    @media (min-width: 640px) {\n      .glass-card { padding: 3rem 3.5rem; }\n    }\n\n    h1, h2, h3 {\n      font-family: 'Playfair Display', serif;\n      font-weight: 600;\n      letter-spacing: 0.02em;\n    }\n\n    .glow-text {\n      background: linear-gradient(135deg, #ffd6c9, #ffb6c1, #ff9eb5);\n      -webkit-background-clip: text;\n      background-clip: text;\n      color: transparent;\n      text-shadow: 0 0 25px var(--glow-pink), 0 0 55px rgba(255,120,140,0.6);\n      animation: softPulse 5s infinite alternate;\n    }\n\n    @keyframes softPulse {\n      0% { text-shadow: 0 0 15px #ffb6c1, 0 0 35px #ff9eb5; }\n      100% { text-shadow: 0 0 30px #ffc2d1, 0 0 65px #ff7eb3; }\n    }\n\n    .hero-title {\n      font-size: clamp(3.2rem, 10vw, 5.5rem);\n      line-height: 1.2;\n      margin-bottom: 0.5rem;\n    }\n\n    .hero-sub {\n      font-size: 1.5rem;\n      font-weight: 300;\n      color: #ffe4ec;\n      text-shadow: 0 0 15px #e6a4b4;\n    }\n\n    .gallery-grid {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));\n      gap: 2rem;\n      margin-top: 2rem;\n    }\n\n    .gallery-item {\n      border-radius: 30px;\n      overflow: hidden;\n      box-shadow: 0 15px 30px -5px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,182,193,0.3);\n      transition: all 0.4s cubic-bezier(0.2,0.9,0.4,1);\n      cursor: pointer;\n      aspect-ratio: 4/5;\n      background: #2b1620;\n    }\n\n    .gallery-item img {\n      width: 100%;\n      height: 100%;\n      object-fit: cover;\n      transition: transform 0.7s;\n    }\n\n    .gallery-item:hover {\n      transform: scale(1.02);\n      box-shadow: 0 0 35px var(--glow-pink), 0 0 60px #ff7eb366;\n      border: 1px solid #ffb6c1;\n    }\n\n    .gallery-item:hover img {\n      transform: scale(1.08);\n    }\n\n    .modal {\n      display: none;\n      position: fixed;\n      inset: 0;\n      background: rgba(10, 5, 8, 0.9);\n      backdrop-filter: blur(20px);\n      z-index: 1000;\n      align-items: center;\n      justify-content: center;\n      padding: 20px;\n    }\n\n    .modal.active {\n      display: flex;\n    }\n\n    .modal-content {\n      max-width: 85vw;\n      max-height: 85vh;\n      border-radius: 40px;\n      box-shadow: 0 0 70px #ffb6c180;\n      border: 2px solid #ffc2d1;\n    }\n\n    .modal-close {\n      position: absolute;\n      top: 30px;\n      right: 40px;\n      font-size: 3rem;\n      color: #ffe4ec;\n      cursor: pointer;\n      filter: drop-shadow(0 0 10px hotpink);\n    }\n\n    .btn {\n      background: linear-gradient(145deg, #ffb6c1, #ff9eb5);\n      border: none;\n      color: #1a0f14;\n      font-weight: 600;\n      padding: 14px 36px;\n      border-radius: 60px;\n      font-size: 1.2rem;\n      box-shadow: 0 10px 25px #00000050, 0 0 30px #ffb6c1;\n      backdrop-filter: blur(5px);\n      transition: 0.3s;\n      border: 1px solid #ffe4ec;\n      cursor: pointer;\n      margin-top: 30px;\n    }\n\n    .btn:hover {\n      transform: scale(1.05);\n      box-shadow: 0 0 45px #ffb6c1;\n    }\n\n    .music-toggle {\n      position: fixed;\n      bottom: 25px;\n      right: 25px;\n      background: var(--glass-bg);\n      backdrop-filter: blur(15px);\n      border: 1px solid #ffb6c1;\n      color: #ffd6c9;\n      border-radius: 60px;\n      padding: 12px 20px;\n      z-index: 100;\n      font-size: 1.2rem;\n      cursor: pointer;\n      box-shadow: 0 0 25px #ffb6c180;\n    }\n\n    .caption-text {\n      font-size: 1rem;\n      margin-top: 10px;\n      color: #ffd6c9;\n    }\n\n    .fade-up {\n      opacity: 0;\n      transform: translateY(35px);\n      transition: opacity 0.9s cubic-bezier(0.2,0.9,0.3,1), transform 0.9s ease;\n    }\n\n    .fade-up.visible {\n      opacity: 1;\n      transform: translateY(0);\n    }\n\n    .heartbeat {\n      animation: heartbeatPulse 2s infinite;\n    }\n\n    @keyframes heartbeatPulse {\n      0%,100%{ transform:scale(1); }\n      15%{ transform:scale(1.06); }\n      30%{ transform:scale(1); }\n      45%{ transform:scale(1.04); }\n    }\n\n    /* responsive */\n    @media (max-width: 600px) {\n      .glass-card { padding: 2rem 1.5rem; }\n    }\n  </style>\n<style>\n      @keyframes burstPop {\n        0% { opacity: 1; transform: scale(0.3) translate(0,0); }\n        100% { opacity: 0; transform: scale(1.5) translate(var(--dx), var(--dy)); }\n      }\n    </style><style id=\"greeter-padding-style\">body { padding-bottom: 0px !important; transition: padding 0.3s; }</style><link id=\"greeter-google-fonts\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Poppins:wght@300;500;700&amp;display=swap\"><style id=\"magic-welcome-styles\">\n                    body.magic-noscroll { overflow: hidden !important; position: fixed !important; width: 100% !important; height: 100% !important; } \n                    .magic-emoji { display: inline-block; -webkit-text-fill-color: initial !important; background: none !important; color: initial !important; animation: magicHeartBeat 2s infinite; } \n                    @keyframes magicHeartBeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }\n                </style><style id=\"magic-flower-keyframes\">@keyframes magicFlowerFall{to{transform:translateY(110vh) rotate(360deg); opacity:0;}}</style><style id=\"magic-balloon-style\">@keyframes magicFloatUp{to{transform:translateY(-120vh);}}</style><style id=\"magicFloatUpKey\">@keyframes magicFloatUp{to{transform:translateY(-120vh);}}</style></head>\n<body class=\"\"><script>(function(){var lang=\"en\";localStorage.setItem(\"greeter_lang\",lang);localStorage.setItem(\"customizer_lang\",lang);var urlParams=new URLSearchParams(window.location.search);if(!urlParams.has(\"lang\")){var newUrl=window.location.href+(window.location.href.indexOf(\"?\")===-1?\"?lang=\"+lang:\"&lang=\"+lang);window.history.replaceState({},\"\",newUrl);}})();</script>\n\n<!-- floating hearts background -->\n<div class=\"floating-bg\" id=\"floatingHeartsContainer\"><div class=\"floating-heart\" style=\"left: 61.342%; animation-duration: 21.9713s; font-size: 3.25369rem;\">💗</div><div class=\"floating-heart\" style=\"left: 12.0397%; animation-duration: 17.463s; font-size: 3.38007rem;\">💓</div><div class=\"floating-heart\" style=\"left: 32.8045%; animation-duration: 15.2138s; font-size: 3.0467rem;\">💗</div><div class=\"floating-heart\" style=\"left: 24.2002%; animation-duration: 17.206s; font-size: 3.08775rem;\">💗</div><div class=\"floating-heart\" style=\"left: 20.7712%; animation-duration: 15.0987s; font-size: 1.75482rem;\">✨</div><div class=\"floating-heart\" style=\"left: 10.7011%; animation-duration: 15.3098s; font-size: 2.51694rem;\">💓</div><div class=\"floating-heart\" style=\"left: 6.22982%; animation-duration: 13.7097s; font-size: 2.6433rem;\">❤️</div><div class=\"floating-heart\" style=\"left: 70.6051%; animation-duration: 17.2545s; font-size: 3.27435rem;\">💖</div><div class=\"floating-heart\" style=\"left: 44.9105%; animation-duration: 19.781s; font-size: 2.05638rem;\">💖</div><div class=\"floating-heart\" style=\"left: 47.9023%; animation-duration: 12.2556s; font-size: 3.04087rem;\">💖</div><div class=\"floating-heart\" style=\"left: 4.81299%; animation-duration: 21.0046s; font-size: 3.36293rem;\">💗</div><div class=\"floating-heart\" style=\"left: 89.542%; animation-duration: 15.9584s; font-size: 2.76735rem;\">💓</div></div>\n\n<!-- music toggle -->\n<div class=\"music-toggle\" id=\"musicToggle\">\n  <i class=\"fas fa-music\"></i> <span id=\"musicText\">Play music</span>\n</div>\n\n<audio id=\"bgMusic\" loop=\"\" preload=\"auto\">\n  <source src=\"https://cdn.pixabay.com/audio/2022/03/10/audio_1f3e8a3d7e.mp3\" type=\"audio/mpeg\">\n</audio>\n\n<div class=\"content\">\n\n  <!-- HERO SECTION -->\n  <section id=\"hero\">\n    <div class=\"glass-card fade-up visible\">\n      <h1 class=\"hero-title glow-text\" id=\"heroTitle\">Happy Birthday Raman <i class=\"fas fa-heart\" style=\"color: #ff9eb5;\"></i></h1>\n      <p class=\"hero-sub\" id=\"heroSub\">Every moment with you is magic</p>\n      <div style=\"margin-top: 20px; font-size: 1.3rem; opacity: 0.9;\" id=\"heroMeta\">Raman · Birthday</div>\n      <div style=\"margin-top: 10px; font-size: 2.5rem;\" class=\"heartbeat\">❤️</div>\n    </div>\n  </section>\n\n  <!-- LOVE MESSAGE / STORY -->\n  <section id=\"storySection\">\n    <div class=\"glass-card fade-up visible\">\n      <h2 class=\"glow-text\" style=\"font-size: 2.8rem; margin-bottom: 25px;\">💌 Our Story</h2>\n      <p style=\"font-size: 1.4rem; line-height: 1.7; font-weight: 300;\" id=\"storyText\">😂🎉 Hey Raman! Another year older, another year wiser? Nah, just more excuses to eat cake and act silly! Hope your birthday is as awesome as you are (which is pretty darn awesome). Don't worry about the gray hairs – they're just sparkles of wisdom. Let's party like we're still 21! 🥳🎈 Also, remember that growing old is mandatory, but growing up is optional – so stay as wonderfully immature as you are! Let's eat cake until we can't move. 🍰😂</p>\n    </div>\n  </section>\n\n  <!-- WISHES SECTION -->\n  <section id=\"wishesSection\">\n    <div class=\"glass-card fade-up visible\">\n      <h2 class=\"glow-text\" style=\"font-size: 2.8rem; margin-bottom: 25px;\">✨ Special Wishes</h2>\n      <p style=\"font-size: 1.4rem; line-height: 1.7; font-weight: 300;\" id=\"wishesText\">🤣 Happy Birthday Raman! Remember, age is just a number – in your case, a really big one now! Just kidding, you're still young at heart (and in denial). May your day be filled with laughter, bad jokes, and enough sugar to keep you hyper for a week. Cheers to another trip around the sun! 🎂😜</p>\n    </div>\n  </section>\n\n  <!-- GALLERY SECTION (if memories exist) -->\n  <section id=\"gallerySection\" style=\"display: block;\">\n    <h2 class=\"glow-text\" style=\"font-size: 3rem; margin-bottom: 20px;\">🌸 Precious Memories</h2>\n    <div class=\"gallery-grid\" id=\"galleryContainer\"><div class=\"gallery-item\">\n          <img src=\"null\" alt=\"memory 1\" loading=\"lazy\">\n          \n        </div><div class=\"gallery-item\">\n          <img src=\"null\" alt=\"memory 2\" loading=\"lazy\">\n          \n        </div><div class=\"gallery-item\">\n          <img src=\"null\" alt=\"memory 3\" loading=\"lazy\">\n          \n        </div></div>\n  </section>\n\n  <!-- INTERACTIVE GIFT / SURPRISE -->\n  <section id=\"giftSection\">\n    <div class=\"glass-card fade-up visible\" style=\"text-align: center;\">\n      <h2 class=\"glow-text\" style=\"font-size: 2.5rem;\">🎁 A Little Surprise</h2>\n      <div style=\"margin: 25px 0;\">\n        <div style=\"background: linear-gradient(145deg, rgb(230, 164, 180), rgb(255, 182, 193)); padding: 1.8rem 2.5rem; border-radius: 60px; display: inline-block; box-shadow: rgba(255, 182, 193, 0.667) 0px 0px 50px; cursor: pointer; transform: scale(0.98);\" id=\"giftBox\">\n          <i class=\"fas fa-gift\" style=\"font-size: 4rem; color: #2e0f17;\"></i>\n          <p style=\"margin-top: 10px; font-weight: 600;\">Click to open</p>\n        </div>\n      </div>\n      <div id=\"giftMessage\" style=\"display: block; font-size: 2rem; color: rgb(255, 240, 245); text-shadow: hotpink 0px 0px 25px;\">\n        <i class=\"fas fa-heart\"></i> You are my everything <i class=\"fas fa-heart\"></i>\n      </div>\n    </div>\n  </section>\n\n  <!-- FINAL SECTION -->\n  <section id=\"finale\">\n    <div class=\"glass-card fade-up visible\">\n      <h1 class=\"glow-text\" style=\"font-size: 3.5rem;\">Forever &amp; Always <i class=\"fas fa-heart\"></i></h1>\n      <p style=\"font-size: 1.6rem; margin: 30px 0;\">Here's to our beautiful journey</p>\n      <button class=\"btn\" id=\"replayBtn\"><i class=\"fas fa-undo-alt\"></i> Replay the Magic</button>\n    </div>\n  </section>\n\n</div>\n\n<!-- Modal for image -->\n<div class=\"modal\" id=\"imageModal\">\n  <span class=\"modal-close\" id=\"closeModal\">×</span>\n  <img class=\"modal-content\" id=\"modalImage\" src=\"null\" alt=\"memory\">\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/canvas-confetti@1\"></script>\n<script>\n  (function(){\n    \"use strict\";\n\n    // ---------- LOAD USER DATA ----------\n    const userData = JSON.parse(localStorage.getItem(\"userData\") || \"{}\");\n    \n    const eventType = userData.event || 'birthday';\n    const mood = userData.mood || 'romantic';\n    const name = userData.name || 'Loved One';\n    const age = userData.age || '';\n    const story = userData.story || 'A beautiful story waiting to be written...';\n    const wishes = userData.wishes || 'May your days be filled with love and joy.';\n    const memories = userData.memories || [];\n\n    // Helper to get event display name\n    function getEventDisplay(eventKey) {\n      const map = {\n        'birthday': 'Birthday',\n        'proposal': 'Proposal',\n        'anniversary': 'Anniversary',\n        'festival': 'Festival'\n      };\n      return map[eventKey] || 'Celebration';\n    }\n\n    const eventDisplay = getEventDisplay(eventType);\n    const ageSuffix = age ? ` · ${age} years young` : '';\n\n    // Update hero\n    document.getElementById('heroTitle').innerHTML = `Happy ${eventDisplay} ${name} <i class=\"fas fa-heart\" style=\"color: #ff9eb5;\"></i>`;\n    document.getElementById('heroSub').innerHTML = mood === 'roast' ? 'You’re still my favorite weirdo 😜' : 'Every moment with you is magic';\n    document.getElementById('heroMeta').innerHTML = `${name}${ageSuffix} · ${eventDisplay}`;\n    \n    document.getElementById('storyText').innerHTML = story.replace(/\\n/g, '<br>');\n    document.getElementById('wishesText').innerHTML = wishes.replace(/\\n/g, '<br>');\n\n    // Gallery\n    const gallerySection = document.getElementById('gallerySection');\n    const galleryContainer = document.getElementById('galleryContainer');\n    if (memories.length > 0) {\n      gallerySection.style.display = 'block';\n      memories.forEach((mem, idx) => {\n        const item = document.createElement('div');\n        item.className = 'gallery-item';\n        item.innerHTML = `\n          <img src=\"${mem.img}\" alt=\"memory ${idx+1}\" loading=\"lazy\">\n          ${mem.text ? `<div class=\"caption-text\">${mem.text}</div>` : ''}\n        `;\n        item.addEventListener('click', () => openModal(mem.img));\n        galleryContainer.appendChild(item);\n      });\n    } else {\n      gallerySection.style.display = 'none';\n    }\n\n    // Modal\n    const modal = document.getElementById('imageModal');\n    const modalImg = document.getElementById('modalImage');\n    function openModal(src) {\n      modal.classList.add('active');\n      modalImg.src = src;\n    }\n    document.getElementById('closeModal').addEventListener('click', () => modal.classList.remove('active'));\n    modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('active'); });\n    window.addEventListener('keydown', (e) => { if(e.key==='Escape') modal.classList.remove('active'); });\n\n    // Floating hearts\n    const heartsContainer = document.getElementById('floatingHeartsContainer');\n    function createHeart() {\n      const heart = document.createElement('div');\n      heart.className = 'floating-heart';\n      heart.innerHTML = ['❤️','🌸','✨','💖','💗','💓'][Math.floor(Math.random()*6)];\n      heart.style.left = Math.random() * 100 + '%';\n      heart.style.animationDuration = (12 + Math.random() * 10) + 's';\n      heart.style.fontSize = (1.4 + Math.random() * 2) + 'rem';\n      heartsContainer.appendChild(heart);\n      setTimeout(() => heart.remove(), 22000);\n    }\n    setInterval(createHeart, 1800);\n    for(let i=0;i<10;i++) setTimeout(createHeart, i*200);\n\n    // Gift box\n    const giftBox = document.getElementById('giftBox');\n    const giftMessage = document.getElementById('giftMessage');\n    let giftOpened = false;\n    giftBox.addEventListener('click', () => {\n      if (giftOpened) return;\n      giftOpened = true;\n      confetti({ particleCount: 200, spread: 100, origin: { y: 0.6 }, colors: ['#ffb6c1', '#ff9eb5', '#ffe4ec'] });\n      confetti({ particleCount: 120, spread: 70, origin: { y: 0.5, x: 0.3 } });\n      confetti({ particleCount: 120, spread: 70, origin: { y: 0.5, x: 0.7 } });\n      giftMessage.style.display = 'block';\n      giftBox.style.transform = 'scale(0.98)';\n      // extra floating hearts\n      for(let i=0;i<15;i++) setTimeout(createHeart, i*50);\n    });\n\n    // Replay button: scroll to top + confetti\n    document.getElementById('replayBtn').addEventListener('click', () => {\n      window.scrollTo({ top: 0, behavior: 'smooth' });\n      confetti({ particleCount: 150, spread: 80, origin: { y: 0.5 } });\n    });\n\n    // Music toggle\n    const bgMusic = document.getElementById('bgMusic');\n    const musicToggle = document.getElementById('musicToggle');\n    const musicText = document.getElementById('musicText');\n    let musicPlaying = false;\n    musicToggle.addEventListener('click', () => {\n      if (!musicPlaying) {\n        bgMusic.volume = 0.2;\n        bgMusic.play().then(() => {\n          musicPlaying = true;\n          musicText.innerText = 'Pause music';\n          musicToggle.innerHTML = '<i class=\"fas fa-pause\"></i> Pause music';\n        }).catch(() => {});\n      } else {\n        bgMusic.pause();\n        musicPlaying = false;\n        musicText.innerText = 'Play music';\n        musicToggle.innerHTML = '<i class=\"fas fa-music\"></i> Play music';\n      }\n    });\n    // autoplay attempt on first interaction\n    document.body.addEventListener('click', function initMusic() {\n      if (bgMusic.paused && !musicPlaying) {\n        bgMusic.play().then(() => {\n          musicPlaying = true;\n          musicText.innerText = 'Pause music';\n          musicToggle.innerHTML = '<i class=\"fas fa-pause\"></i> Pause music';\n        }).catch(()=>{});\n      }\n    }, { once: true });\n\n    // Intersection Observer for fade-up\n    const fadeElements = document.querySelectorAll('.fade-up');\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('visible');\n        }\n      });\n    }, { threshold: 0.2, rootMargin: '0px' });\n    fadeElements.forEach(el => observer.observe(el));\n    \n    // Additional micro interactions: click heart burst\n    document.body.addEventListener('click', (e) => {\n      const x = e.clientX;\n      const y = e.clientY;\n      for(let i=0; i<8; i++) {\n        const heart = document.createElement('div');\n        heart.innerHTML = '❤️';\n        heart.style.position = 'fixed';\n        heart.style.left = x + 'px';\n        heart.style.top = y + 'px';\n        heart.style.fontSize = '2rem';\n        heart.style.pointerEvents = 'none';\n        heart.style.zIndex = '9999';\n        heart.style.filter = 'drop-shadow(0 0 15px #ffb6c1)';\n        heart.style.animation = 'burstPop 1.2s forwards';\n        const angle = (i * 45) * Math.PI/180;\n        const distance = 60 + Math.random()*100;\n        const dx = Math.cos(angle) * distance;\n        const dy = Math.sin(angle) * distance;\n        heart.style.setProperty('--dx', dx+'px');\n        heart.style.setProperty('--dy', dy+'px');\n        document.body.appendChild(heart);\n        setTimeout(() => heart.remove(), 1100);\n      }\n    });\n\n    // Add keyframes dynamically\n    const styleSheet = document.createElement(\"style\");\n    styleSheet.textContent = `\n      @keyframes burstPop {\n        0% { opacity: 1; transform: scale(0.3) translate(0,0); }\n        100% { opacity: 0; transform: scale(1.5) translate(var(--dx), var(--dy)); }\n      }\n    `;\n    document.head.appendChild(styleSheet);\n\n    console.log('✨ Personalized surprise for', name);\n  })();\n</script>\n\n<!-- extra style for caption -->\n<style>\n  .caption-text {\n    position: absolute;\n    bottom: 10px;\n    left: 0;\n    right: 0;\n    background: rgba(0,0,0,0.4);\n    backdrop-filter: blur(5px);\n    padding: 8px;\n    text-align: center;\n    border-radius: 0 0 30px 30px;\n  }\n  .gallery-item { position: relative; }\n  .floating-heart { will-change: transform; }\n  .btn, .music-toggle, #giftBox { cursor: pointer; }\n</style>\n\n\n</body></html>","config":{"activeFeatures":[["curtainReveal",true],["welcomeTyping",true],["fireworksText",true],["flowerRain",true],["canvasStarfall",true],["balloonParty",true],["floatingBalloonsNamed",true]],"customData":[["curtainReveal",{"text":"","images":[],"emoji":""}],["welcomeTyping",{"text":"✨ A Special Surprise Is Waiting For You ✨","images":[],"emoji":""}],["fireworksText",{"text":"Happy Birthday Raman! 🎂🎉","images":[],"emoji":""}],["flowerRain",{"text":"","images":[],"emoji":"🌸🌻🌺💐"}],["canvasStarfall",{"text":"","images":[],"emoji":""}],["balloonParty",{"text":"","images":[],"emoji":"🎈"}],["floatingBalloonsNamed",{"text":"Raman","images":[],"emoji":""}]],"