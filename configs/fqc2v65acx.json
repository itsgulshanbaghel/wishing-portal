{"html":"<!DOCTYPE html>\n<html lang=\"en\"><head>\n<meta charset=\"utf-8\">\n<title>Error</title>\n<style id=\"greeter-padding-style\">body { padding-bottom: 80px !important; transition: padding 0.3s; }</style><link id=\"greeter-google-fonts\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Poppins:wght@300;500;700&amp;display=swap\"><style id=\"magic-welcome-styles\">\n                    body.magic-noscroll { overflow: hidden !important; position: fixed !important; width: 100% !important; height: 100% !important; } \n                    .magic-emoji { display: inline-block; -webkit-text-fill-color: initial !important; background: none !important; color: initial !important; animation: magicHeartBeat 2s infinite; } \n                    @keyframes magicHeartBeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }\n                </style><style id=\"magic-flower-keyframes\">@keyframes magicFlowerFall{to{transform:translateY(110vh) rotate(360deg); opacity:0;}}</style><style id=\"magic-swan-keyframes\">@keyframes magicSwanFly{0%{transform:translateX(0); opacity:0;}10%{opacity:1;}100%{transform:translateX(-130vw); opacity:0;}}</style><style id=\"magic-gift-styles\">#gift-box-emoji { animation: giftWobble 2s infinite ease-in-out; } @keyframes giftWobble { 0%,100%{transform:rotate(0) scale(1);} 25%{transform:rotate(-8deg) scale(1.1);} 75%{transform:rotate(8deg) scale(1.1);} }</style><style id=\"gift-reveal-key\">@keyframes giftRevealPop{from{transform:scale(0.5);opacity:0;}to{transform:scale(1);opacity:1;}}</style><style id=\"magic-polaroid-style\">@keyframes magicPolaroidUp{0%{opacity:0; transform:translateY(0);} 10%{opacity:1;} 90%{opacity:1;} 100%{transform:translateY(-150vh); opacity: 0;}}</style><style id=\"magicFloatUpKey\">@keyframes magicFloatUp{to{transform:translateY(-120vh);}}</style><style id=\"magic-balloon-style\">@keyframes magicFloatUp{to{transform:translateY(-120vh);}}</style><style id=\"magic-bomb-styles\">@keyframes bombWobble{from{transform:rotate(-5deg) scale(1);}to{transform:rotate(5deg) scale(1.1);}} @keyframes fuseSpark{0%,100%{opacity:1; transform:scale(1);} 50%{opacity:0.5; transform:scale(1.5);}}</style><style id=\"magic-heart-style\">@keyframes magicHeartFall{to{transform:translateY(110vh) rotate(25deg); opacity:0;}}</style></head>\n<body class=\"\"><script>(function(){var lang=\"en\";localStorage.setItem(\"greeter_lang\",lang);localStorage.setItem(\"customizer_lang\",lang);var urlParams=new URLSearchParams(window.location.search);if(!urlParams.has(\"lang\")){var newUrl=window.location.href+(window.location.href.indexOf(\"?\")===-1?\"?lang=\"+lang:\"&lang=\"+lang);window.history.replaceState({},\"\",newUrl);}})();</script>\n<pre>Cannot GET /templates/proposal1.html</pre>\n\n\n</body></html>","config":{"activeFeatures":[["welcomeTyping",true],["curtainReveal",true],["flowerRain",true],["canvasStarfall",true],["flyingSwans",true],["giftBoxOpen",true],["textFormation",true],["oldPaperLetter",true],["hugSkyLetter",true],["floatingPolaroids",true],["finalSurprise",true],["magicMusic",true],["floatingBalloonsNamed",true],["balloonParty",true],["fireworksText",true],["scratchReveal",true],["memoryTimeline",true],["fireworksClick",true],["bombExplosion",true],["heartsOnScroll",true]],"customData":[["welcomeTyping",{"text":"✨ Your Birthday Surprise Is Waiting For You ✨","images":[],"emoji":""}],["curtainReveal",{"text":"","images":[],"emoji":""}],["flowerRain",{"text":"","images":[],"emoji":"🌸🌻🌺💐"}],["canvasStarfall",{"text":"","images":[],"emoji":""}],["flyingSwans",{"text":"","images":[],"emoji":"🦢"}],["giftBoxOpen",{"text":"🎀 A special gift for you! 🎀","images":[],"emoji":""}],["textFormation",{"text":"✨ This moment is magical! 💖","images":[],"emoji":""}],["oldPaperLetter",{"text":"My dearest friend, on this birthday, may your heart be filled with joy. With love, 💌","images":[],"emoji":""}],["hugSkyLetter",{"text":"💌 My dearest Raman, you are my sunsh