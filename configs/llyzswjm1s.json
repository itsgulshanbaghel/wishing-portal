{"html":"<!DOCTYPE html>\n<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=yes, viewport-fit=cover\">\n    <title>🎉 Celebration Spectacular · Greeter.com</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Poppins:wght@300;500;700;800&amp;display=swap\" rel=\"stylesheet\">\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: 'Poppins', sans-serif;\n            background: linear-gradient(145deg, #1a0b2e, #0f0520);\n            color: #fff0e0;\n            overflow-x: hidden;\n        }\n\n        section {\n            min-height: 100vh;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            padding: 2rem;\n            scroll-snap-align: start;\n        }\n\n        html {\n            scroll-snap-type: y mandatory;\n            scroll-behavior: smooth;\n        }\n\n        .particle-bg {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            pointer-events: none;\n            z-index: 0;\n        }\n\n        .particle {\n            position: absolute;\n            background: rgba(255, 215, 0, 0.6);\n            border-radius: 50%;\n            animation: floatParticle linear infinite;\n        }\n\n        @keyframes floatParticle {\n            0% {\n                transform: translateY(100vh) rotate(0deg);\n                opacity: 0;\n            }\n\n            10% {\n                opacity: 0.8;\n            }\n\n            90% {\n                opacity: 0.5;\n            }\n\n            100% {\n                transform: translateY(-20vh) rotate(360deg);\n                opacity: 0;\n            }\n        }\n\n        .glass-card {\n            background: rgba(20, 15, 40, 0.65);\n            backdrop-filter: blur(16px);\n            border-radius: 48px;\n            border: 1px solid rgba(255, 215, 0, 0.5);\n            padding: 2rem;\n            max-width: 800px;\n            width: 100%;\n            margin: 0 auto;\n            box-shadow: 0 25px 45px rgba(0, 0, 0, 0.3);\n            transition: transform 0.3s;\n            text-align: center;\n        }\n\n        .glass-card:hover {\n            transform: translateY(-5px);\n            border-color: #ffaa44;\n        }\n\n        h1 {\n            font-family: 'Great Vibes', cursive;\n            font-size: 4rem;\n            background: linear-gradient(135deg, #FFD966, #FFA500, #FF69B4);\n            -webkit-background-clip: text;\n            background-clip: text;\n            color: transparent;\n            text-shadow: 0 0 20px rgba(255, 200, 0, 0.5);\n            margin-bottom: 1rem;\n        }\n\n        h2 {\n            font-size: 2rem;\n            margin-bottom: 1rem;\n            color: #ffd966;\n        }\n\n        p {\n            font-size: 1.2rem;\n            line-height: 1.6;\n        }\n\n        button {\n            background: linear-gradient(145deg, #ff9a3c, #ff5e00);\n            border: none;\n            padding: 12px 28px;\n            border-radius: 60px;\n            font-weight: bold;\n            color: white;\n            cursor: pointer;\n            transition: 0.2s;\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);\n            margin: 0.5rem;\n            font-size: 1rem;\n        }\n\n        button:hover {\n            transform: scale(1.05);\n            filter: brightness(1.1);\n        }\n\n        .memories-wrapper {\n            display: flex;\n            overflow-x: auto;\n            gap: 24px;\n            padding: 20px 10px;\n            scroll-snap-type: x mandatory;\n            margin-top: 1rem;\n        }\n\n        .memory-card {\n            flex: 0 0 auto;\n            background: rgba(0, 0, 0, 0.6);\n            border-radius: 32px;\n            border: 2px solid #ffb347;\n            padding: 16px;\n            scroll-snap-align: start;\n            transition: transform 0.2s;\n            text-align: left;\n            position: relative;\n            width: 280px;\n            height: 400px;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .memory-card:hover {\n            transform: translateY(-8px);\n            border-color: #ffdd88;\n        }\n\n        .memory-remove {\n            position: absolute;\n            top: 8px;\n            right: 8px;\n            background: rgba(220, 20, 60, 0.9);\n            color: white;\n            width: 28px;\n            height: 28px;\n            border-radius: 50%;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 14px;\n            cursor: pointer;\n            transition: 0.2s;\n            z-index: 10;\n            border: none;\n        }\n\n        .memory-remove:hover {\n            background: #ff3333;\n            transform: scale(1.1);\n        }\n\n        .resize-handle {\n            position: absolute;\n            bottom: 4px;\n            right: 4px;\n            width: 24px;\n            height: 24px;\n            background: rgba(255, 165, 0, 0.8);\n            border-radius: 12px;\n            cursor: nw-resize;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 12px;\n            color: white;\n            z-index: 10;\n            backdrop-filter: blur(4px);\n            transition: 0.1s;\n        }\n\n        .resize-handle:hover {\n            background: #ff7a2f;\n            transform: scale(1.05);\n        }\n\n        .image-slot {\n            width: 100%;\n            background: #2a1a3a;\n            border-radius: 24px;\n            overflow: hidden;\n            position: relative;\n            border: 1px solid #ffb347;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            flex: 1 1 auto;\n            min-height: 150px;\n        }\n\n        .image-slot img {\n            max-width: 100%;\n            max-height: 100%;\n            width: auto;\n            height: auto;\n            display: block;\n            object-fit: contain;\n        }\n\n        .image-placeholder {\n            width: 100%;\n            min-height: 150px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            background: #2a1a3a;\n            color: #ffb347;\n            font-size: 1rem;\n            text-align: center;\n            gap: 10px;\n            padding: 20px;\n        }\n\n        .image-placeholder i {\n            font-size: 2.5rem;\n        }\n\n        .image-actions {\n            display: flex;\n            gap: 8px;\n            margin-top: 12px;\n            justify-content: center;\n            flex-wrap: wrap;\n        }\n\n        .img-btn {\n            background: #ff7a2f;\n            padding: 4px 12px;\n            border-radius: 30px;\n            font-size: 0.75rem;\n            font-weight: bold;\n            border: none;\n            color: white;\n            cursor: pointer;\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n        }\n\n        .img-btn i {\n            font-size: 0.8rem;\n        }\n\n        .gift-box {\n            font-size: 5rem;\n            cursor: pointer;\n            transition: 0.2s;\n            animation: bounce 2s infinite;\n            display: inline-block;\n            margin: 1rem 0;\n        }\n\n        @keyframes bounce {\n\n            0%,\n            100% {\n                transform: translateY(0);\n            }\n\n            50% {\n                transform: translateY(-15px);\n            }\n        }\n\n        .balloon {\n            position: fixed;\n            bottom: -100px;\n            font-size: 2.5rem;\n            pointer-events: none;\n            z-index: 100;\n            animation: rise 8s linear forwards;\n        }\n\n        @keyframes rise {\n            to {\n                transform: translateY(-120vh);\n            }\n        }\n\n        .curtain {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            z-index: 10000;\n            display: flex;\n            pointer-events: none;\n        }\n\n        .curtain-panel {\n            flex: 1;\n            background: repeating-linear-gradient(90deg, #7a2e2e, #c44c4c);\n            transition: transform 1.5s ease-in-out;\n            pointer-events: auto;\n        }\n\n        .curtain-left {\n            transform-origin: left;\n        }\n\n        .curtain-right {\n            transform-origin: right;\n        }\n\n        .curtain.open .curtain-left {\n            transform: translateX(-100%);\n        }\n\n        .curtain.open .curtain-right {\n            transform: translateX(100%);\n        }\n\n        .fade-up {\n            opacity: 0;\n            transform: translateY(30px);\n            transition: opacity 0.8s ease, transform 0.8s ease;\n        }\n\n        .fade-up.visible {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        @media (max-width: 768px) {\n            section {\n                padding: 1rem;\n            }\n\n            .glass-card {\n                padding: 1.5rem;\n                max-width: 95%;\n            }\n\n            h1 {\n                font-size: 2.5rem;\n            }\n\n            h2 {\n                font-size: 1.6rem;\n            }\n\n            p {\n                font-size: 1rem;\n            }\n\n            button {\n                padding: 8px 20px;\n                font-size: 0.9rem;\n            }\n\n            .gift-box {\n                font-size: 3.5rem;\n            }\n\n            .memory-card {\n                width: 240px;\n                height: 360px;\n            }\n\n            .resize-handle {\n                width: 20px;\n                height: 20px;\n                font-size: 10px;\n            }\n\n            .image-placeholder {\n                font-size: 0.8rem;\n                min-height: 120px;\n            }\n\n            .image-placeholder i {\n                font-size: 1.8rem;\n            }\n        }\n\n        @media (max-width: 480px) {\n            .glass-card {\n                padding: 1rem;\n            }\n\n            h1 {\n                font-size: 2rem;\n            }\n\n            h2 {\n                font-size: 1.3rem;\n            }\n        }\n    </style>\n<style id=\"greeter-padding-style\">body { padding-bottom: 80px !important; transition: padding 0.3s; }</style><link id=\"greeter-google-fonts\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Poppins:wght@300;500;700&amp;display=swap\"><style id=\"magic-welcome-styles\">\n                    body.magic-noscroll { overflow: hidden !important; position: fixed !important; width: 100% !important; height: 100% !important; } \n                    .magic-emoji { display: inline-block; -webkit-text-fill-color: initial !important; background: none !important; color: initial !important; animation: magicHeartBeat 2s infinite; } \n                    @keyframes magicHeartBeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }\n                </style><style id=\"magic-flower-keyframes\">@keyframes magicFlowerFall{to{transform:translateY(110vh) rotate(360deg); opacity:0;}}</style><style id=\"magic-swan-keyframes\">@keyframes magicSwanFly{0%{transform:translateX(0); opacity:0;}10%{opacity:1;}100%{transform:translateX(-130vw); opacity:0;}}</style><style id=\"magic-balloon-style\">@keyframes magicFloatUp{to{transform:translateY(-120vh);}}</style><style id=\"magicFloatUpKey\">@keyframes magicFloatUp{to{transform:translateY(-120vh);}}</style><style id=\"magic-bomb-styles\">@keyframes bombWobble{from{transform:rotate(-5deg) scale(1);}to{transform:rotate(5deg) scale(1.1);}} @keyframes fuseSpark{0%,100%{opacity:1; transform:scale(1);} 50%{opacity:0.5; transform:scale(1.5);}}</style><style id=\"magic-gift-styles\">#gift-box-emoji { animation: giftWobble 2s infinite ease-in-out; } @keyframes giftWobble { 0%,100%{transform:rotate(0) scale(1);} 25%{transform:rotate(-8deg) scale(1.1);} 75%{transform:rotate(8deg) scale(1.1);} }</style></head>\n\n<body class=\"\" contenteditable=\"false\"><script>(function(){var lang=\"en\";localStorage.setItem(\"greeter_lang\",lang);localStorage.setItem(\"customizer_lang\",lang);var urlParams=new URLSearchParams(window.location.search);if(!urlParams.has(\"lang\")){var newUrl=window.location.href+(window.location.href.indexOf(\"?\")===-1?\"?lang=\"+lang:\"&lang=\"+lang);window.history.replaceState({},\"\",newUrl);}})();</script>\n\n    <div class=\"particle-bg\" id=\"particleBg\"><div class=\"particle\" style=\"width: 13.0658px; height: 13.0658px; left: 88.3391%; animation-duration: 6.82098s; animation-delay: 1.66295s; background: rgb(255, 215, 51);\"></div><div class=\"particle\" style=\"width: 12.9139px; height: 12.9139px; left: 30.9663%; animation-duration: 14.4949s; animation-delay: 3.82084s; background: rgb(250, 255, 51);\"></div><div class=\"particle\" style=\"width: 8.07002px; height: 8.07002px; left: 76.8611%; animation-duration: 9.68986s; animation-delay: 1.79572s; background: rgb(255, 181, 51);\"></div><div class=\"particle\" style=\"width: 6.80856px; height: 6.80856px; left: 18.7262%; animation-duration: 9.69816s; animation-delay: 1.00111s; background: rgb(255, 163, 51);\"></div><div class=\"particle\" style=\"width: 15.0595px; height: 15.0595p