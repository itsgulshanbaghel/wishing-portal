{"html":"<!DOCTYPE html>\n<html lang=\"en\"><head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n  <title>🎂 Enchanted Birthday · Greeter.com</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Poppins:wght@300;500;700&amp;family=Cinzel:wght@400;700&amp;display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\">\n  <style>\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    body {\n      font-family: 'Poppins', sans-serif;\n      background: #0f0c29;\n      color: white;\n      overflow-x: hidden;\n      scroll-behavior: smooth;\n    }\n    section {\n      min-height: 100vh;\n      display: flex;\n      flex-direction: column;\n      justify-content: center;\n      align-items: center;\n      padding: 2rem 1rem;\n      text-align: center;\n    }\n    .glass-card {\n      background: rgba(255, 255, 255, 0.08);\n      backdrop-filter: blur(15px);\n      border: 1px solid rgba(255, 255, 255, 0.1);\n      border-radius: 40px;\n      padding: 40px;\n      max-width: 1400px;\n      width: 100%;\n      box-shadow: 0 25px 40px -10px rgba(0, 0, 0, 0.5);\n    }\n    h1 {\n      font-family: 'Great Vibes', cursive;\n      font-size: clamp(3rem, 10vw, 5rem);\n      background: linear-gradient(45deg, #ff0080, #ff8c00, #ffd700);\n      -webkit-background-clip: text;\n      background-clip: text;\n      color: transparent;\n      margin-bottom: 20px;\n    }\n    h2 {\n      font-size: 2.5rem;\n      margin-bottom: 20px;\n      color: #ffd700;\n      font-family: 'Cinzel', serif;\n    }\n    button {\n      background: linear-gradient(45deg, #ff0080, #ff8c00);\n      border: none;\n      color: white;\n      padding: 12px 28px;\n      border-radius: 60px;\n      font-weight: 600;\n      font-size: 1rem;\n      cursor: pointer;\n      transition: 0.3s;\n      box-shadow: 0 10px 25px rgba(255, 0, 128, 0.3);\n      margin: 8px;\n    }\n    button:hover {\n      transform: translateY(-3px);\n      box-shadow: 0 15px 35px rgba(255, 0, 128, 0.5);\n    }\n\n    .timeline-wrapper {\n      display: flex;\n      justify-content: safe center;\n      gap: 25px;\n      padding: 30px 20px;\n      overflow-x: auto;\n      scroll-snap-type: x mandatory;\n      scroll-behavior: smooth;\n      cursor: grab;\n      scrollbar-width: thin;\n      scrollbar-color: #ff8c00 #2a1e3c;\n      width: 100%;\n    }\n    .timeline-wrapper::-webkit-scrollbar { height: 10px; }\n    .timeline-wrapper::-webkit-scrollbar-thumb { background: #ff8c00; border-radius: 20px; }\n    .timeline-wrapper:active { cursor: grabbing; }\n\n    .memory-card {\n      flex: 0 0 auto;\n      width: 280px;\n      background: rgba(30, 20, 40, 0.92);\n      backdrop-filter: blur(12px);\n      border-radius: 32px;\n      border: 1px solid rgba(255, 180, 200, 0.5);\n      padding: 20px 18px;\n      box-shadow: 0 20px 30px -12px rgba(0, 0, 0, 0.6);\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      color: #f0e0ff;\n      transition: transform 0.2s;\n      scroll-snap-align: center;\n      position: relative;\n      user-select: none;\n    }\n    .memory-card:hover { transform: translateY(-5px); }\n\n    .memory-card.add-card {\n      background: rgba(100, 50, 120, 0.85);\n      border: 2px dashed #ffb6c7;\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      cursor: pointer;\n      width: 240px;\n      min-height: 360px;\n    }\n    .add-card-content {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 12px;\n      color: #ffdab9;\n      font-size: 1.3rem;\n    }\n    .add-card-content i { font-size: 3rem; }\n\n    .remove-card-btn {\n      position: absolute;\n      top: 12px; right: 12px;\n      background: rgba(180, 80, 100, 0.9);\n      border: none; color: white;\n      width: 36px; height: 36px;\n      border-radius: 30px;\n      font-size: 1.1rem;\n      cursor: pointer;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      backdrop-filter: blur(4px);\n      z-index: 10;\n    }\n    .remove-card-btn:hover { background: #e53e3e; transform: scale(1.1); }\n\n    .resize-handle {\n      position: absolute;\n      bottom: 8px; right: 8px;\n      width: 28px; height: 28px;\n      cursor: nwse-resize;\n      color: rgba(255, 220, 200, 0.9);\n      font-size: 18px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      background: rgba(0,0,0,0.3);\n      border-radius: 14px;\n      backdrop-filter: blur(4px);\n      z-index: 10;\n      transition: 0.1s;\n    }\n    .resize-handle:hover { color: #ffd700; background: rgba(255,140,200,0.5); }\n    .resize-handle:active { cursor: nwse-resize; background: #ff4da6; }\n\n    .image-slot {\n      width: 100%;\n      aspect-ratio: 1 / 1;\n      background: rgba(255, 220, 240, 0.1);\n      border-radius: 24px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      overflow: hidden;\n      margin-bottom: 15px;\n      border: 2px dashed #ffb6c7;\n      position: relative;\n    }\n    .image-slot img { \n      width: 100%; \n      height: 100%; \n      object-fit: cover; \n      display: block; \n    }\n    .image-slot .placeholder-text {\n      position: absolute;\n      top: 0;\n      left: 0;\n      width: 100%;\n      height: 100%;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      color: #e6b0c0;\n      font-weight: 600;\n      gap: 8px;\n      background: rgba(0,0,0,0.3);\n      backdrop-filter: blur(4px);\n      border-radius: 24px;\n    }\n    .placeholder-text i { font-size: 2.5rem; opacity: 0.9; }\n\n    .image-actions {\n      display: flex;\n      gap: 8px;\n      margin: 12px 0 8px;\n      flex-wrap: wrap;\n      justify-content: center;\n    }\n    .img-btn {\n      background: rgba(255, 220, 210, 0.15);\n      border: 1px solid rgba(255, 200, 220, 0.5);\n      border-radius: 40px;\n      padding: 6px 14px;\n      font-size: 0.8rem;\n      font-weight: bold;\n      color: #ffdab9;\n      cursor: pointer;\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      backdrop-filter: blur(8px);\n      transition: 0.2s;\n    }\n    .img-btn:hover { background: #ff0080; border-color: #ff0080; color: white; }\n    .remove-btn.img-btn:hover { background: #e53e3e; }\n\n    .memory-year {\n      font-family: 'Cinzel', serif;\n      font-size: 1.6rem;\n      color: #ffb6c1;\n      margin: 8px 0 4px;\n      text-shadow: 0 0 8px #ff69b4;\n    }\n    .memory-caption {\n      font-weight: 600;\n      color: #e0c0ff;\n      font-size: 1rem;\n    }\n\n    #curtain {\n      position: fixed; inset: 0; z-index: 1000; display: flex; background: #2b0000;\n    }\n    .panel { flex: 1; background: repeating-linear-gradient(90deg, #7a0000, #a00000 40px); transition: transform 2s; }\n    .left { transform-origin: left; } .right { transform-origin: right; }\n    #curtain.open .left { transform: translateX(-110%); } #curtain.open .right { transform: translateX(110%); }\n    #welcomeMsg {\n      position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;\n      pointer-events: none; color: white; text-shadow: 0 0 30px gold;\n      font-size: 4rem; font-family: 'Great Vibes', cursive;\n    }\n    #effectsCanvas { position: fixed; top: 0; left: 0; pointer-events: none; z-index: 5; }\n\n    .fade-up { opacity: 0; transform: translateY(30px); transition: 0.8s; }\n    .fade-up.visible { opacity: 1; transform: translateY(0); }\n\n    @keyframes float { 0%,100%{ transform:translateY(0); } 50%{ transform:translateY(-15px); } }\n    .floating { animation: float 5s infinite; }\n\n    .gallery-note { color: #ffdab9; margin-bottom: 5px; }\n  </style>\n<style>@keyframes heartFloat{0%{opacity:1;transform:scale(0.6) translateY(0);}100%{opacity:0;transform:scale(0.3) translateY(-70px);}}</style><style id=\"greeter-padding-style\">body { padding-bottom: 0px !important; transition: padding 0.3s; }</style></head>\n<body><script>(function(){var lang=\"en\";localStorage.setItem(\"greeter_lang\",lang);localStorage.setItem(\"customizer_lang\",lang);var urlParams=new URLSearchParams(window.location.search);if(!urlParams.has(\"lang\")){var newUrl=window.location.href+(window.location.href.indexOf(\"?\")===-1?\"?lang=\"+lang:\"&lang=\"+lang);window.history.replaceState({},\"\",newUrl);}})();</script>\n\n<div id=\"curtain\" class=\"open\" style=\"display: none;\">\n  <div class=\"panel left\"></div>\n  <div class=\"panel right\"></div>\n  <div id=\"welcomeMsg\">✨ Welcome, John! ✨</div>\n</div>\n<canvas id=\"effectsCanvas\" width=\"833\" height=\"450\"></canvas>\n\n<!-- Hero -->\n<section id=\"hero\">\n  <div class=\"glass-card fade-up visible\">\n    <h1 id=\"heroTitle\">Happy Birthday, John!</h1>\n    <p id=\"heroSub\" style=\"font-size:1.5rem; margin-bottom:20px;\">🎈 Let's make this day unforgettable 🎈</p>\n    <button id=\"viewMemoriesBtn\"><i class=\"fas fa-images\"></i> View Memories</button>\n  </div>\n</section>\n\n<!-- Story -->\n<section id=\"story\">\n  <div class=\"glass-card fade-up\">\n    <h2 id=\"storyHeading\">💌 A Special Message</h2>\n    <p id=\"storyText\" style=\"font-size:1.3rem; line-height:1.8;\">Every year on this day, the world became a little brighter because you were born. Today we celebrate you!</p>\n  </div>\n</section>\n\n<!-- Gallery -->\n<section id=\"gallery\" style=\"display: flex;\">\n  <div class=\"glass-card fade-up\" style=\"overflow: visible;\">\n    <h2 id=\"galleryHeading\">📸 Precious Memories</h2>\n    <p id=\"galleryNote\" class=\"gallery-note\">Some of the most treasured moments.</p>\n    <div class=\"timeline-wrapper\" id=\"timelineContainer\"><div class=\"memory-card\" data-index=\"0\" style=\"width: 280px;\"><button class=\"remove-card-btn\"><i class=\"fas fa-times-circle\"></i></button><div class=\"image-slot\"><div class=\"placeholder-text\" style=\"display: flex;\"><i class=\"fas fa-camera\"></i><span>📸 Click to upload an image</span></div><img src=\"\" style=\"display: none;\"></div><div class=\"image-actions\"><button class=\"img-btn\"><i class=\"fas fa-upload\"></i> Upload</button><button class=\"img-btn\"><i class=\"fas fa-sync-alt\"></i> Replace</button><button class=\"img-btn remove-btn\"><i class=\"fas fa-trash-alt\"></i> Remove</button></div><input type=\"file\" accept=\"image/*\" style=\"display: none;\"><div class=\"memory-year\">✨ 2023</div><div class=\"memory-caption\">First magical laugh</div><div class=\"resize-handle\"><i class=\"fas fa-chevron-circle-down\"></i></div></div><div class=\"memory-card\" data-index=\"1\" style=\"width: 280px;\"><button class=\"remove-card-btn\"><i class=\"fas fa-times-circle\"></i></button><div class=\"image-slot\"><div class=\"placeholder-text\" style=\"display: flex;\"><i class=\"fas fa-camera\"></i><span>📸 Click to upload an image</span></div><img src=\"\" style=\"display: none;\"></div><div class=\"image-actions\"><button class=\"img-btn\"><i class=\"fas fa-upload\"></i> Upload</button><button class=\"img-btn\"><i class=\"fas fa-sync-alt\"></i> Replace</button><button class=\"img-btn remove-btn\"><i class=\"fas fa-trash-alt\"></i> Remove</button></div><input type=\"file\" accept=\"image/*\" style=\"display: none;\"><div class=\"memory-year\">🌻 2024</div><div class=\"memory-caption\">Golden adventures</div><div class=\"resize-handle\"><i class=\"fas fa-chevron-circle-down\"></i></div></div><div class=\"memory-card\" data-index=\"2\" style=\"width: 280px;\"><button class=\"remove-card-btn\"><i class=\"fas fa-times-circle\"></i></button><div class=\"image-slot\"><div class=\"placeholder-text\" style=\"display: flex;\"><i class=\"fas fa-camera\"></i><span>📸 Click to upload an image</span></div><img src=\"\" style=\"display: none;\"></div><div class=\"image-actions\"><button class=\"img-btn\"><i class=\"fas fa-upload\"></i> Upload</button><button class=\"img-btn\"><i class=\"fas fa-sync-alt\"></i> Replace</button><button class=\"img-btn remove-btn\"><i class=\"fas fa-trash-alt\"></i> Remove</button></div><input type=\"file\" accept=\"image/*\" style=\"display: none;\"><div class=\"memory-year\">⭐️ 2025</div><div class=\"memory-caption\">Starlight dreams</div><div class=\"resize-handle\"><i class=\"fas fa-chevron-circle-down\"></i></div></div><div class=\"memory-card\" data-index=\"3\" style=\"width: 280px;\"><button class=\"remove-card-btn\"><i class=\"fas fa-times-circle\"></i></button><div class=\"image-slot\"><div class=\"placeholder-text\" style=\"display: flex;\"><i class=\"fas fa-camera\"></i><span>📸 Click to upload an image</span></div><img src=\"\" style=\"display: none;\"></div><div class=\"image-actions\"><button class=\"img-btn\"><i class=\"fas fa-upload\"></i> Upload</button><button class=\"img-btn\"><i class=\"fas fa-sync-alt\"></i> Replace</button><button class=\"img-btn remove-btn\"><i class=\"fas fa-trash-alt\"></i> Remove</button></div><input type=\"file\" accept=\"image/*\" style=\"display: none;\"><div class=\"memory-year\">🎉 Today</div><div class=\"memory-caption\">Your radiant birthday</div><div class=\"resize-handle\"><i class=\"fas fa-chevron-circle-down\"></i></div></div><div class=\"memory-card add-card\">\n        <div class=\"add-card-content\">\n          <i class=\"fas fa-plus-circle\"></i>\n          <span>➕ Add Memory</span>\n          <small>click to create new</small>\n        </div>\n      </div></div>\n  </div>\n</section>\n\n<!-- Wishes -->\n<section id=\"wishes\">\n  <div class=\"glass-card fade-up\">\n    <h2 id=\"wishesHeading\">✨ Birthday Wishes</h2>\n    <p id=\"wishesText\" style=\"font-size:1.3rem;\">May your day be filled with laughter, love, and all the cake you can eat! 🎂✨</p>\n  </div>\n</section>\n\n<!-- Surprise -->\n<section id=\"surprise\">\n  <div class=\"glass-card fade-up\">\n    <h2 id=\"surpriseHeading\">🎁 A Special Surprise</h2>\n    <div id=\"giftBox\" style=\"font-size:6rem; cursor:pointer;\" class=\"floating\" onclick=\"revealGift()\">🎁</div>\n    <div id=\"giftReveal\" style=\"display:none; margin-top:20px;\">\n      <h3 id=\"giftMessage\" style=\"color:#ffd700;\">You are the most wonderful gift! 💖</h3>\n      <button id=\"celebrateBtn\"><i class=\"fas fa-fire\"></i> Celebrate</button>\n    </div>\n  </div>\n</section>\n\n<script src=\"https://cdn.jsdelivr.net/npm/canvas-confetti@1\"></script>\n<script>\n  (function(){\n    // ---------- TRANSLATIONS ----------\n    const translations = {\n      en: {\n        welcomeMsg: (name) => `✨ Welcome, ${name}! ✨`,\n        heroTitle: (name) => `Happy Birthday, ${name}!`,\n        heroSub: \"🎈 Let's make this day unforgettable 🎈\",\n        viewMemories: \"View Memories\",\n        storyHeading: \"💌 A Special Message\",\n        storyDefault: \"Every year on this day, the world became a little brighter because you were born. Today we celebrate you!\",\n        galleryHeading: \"📸 Precious Memories\",\n        galleryNote: \"Some of the most treasured moments.\",\n        wishesHeading: \"✨ Birthday Wishes\",\n        wishesDefault: \"May your day be filled with laughter, love, and all the cake you can eat! 🎂✨\",\n        surpriseHeading: \"🎁 A Special Surprise\",\n        giftMessage: \"You are the most wonderful gift! 💖\",\n        celebrate: \"Celebrate\",\n        memoryYears: [\"✨ 2023\", \"🌻 2024\", \"⭐️ 2025\", \"🎉 Today\"],\n        memoryCaps: [\"First magical laugh\", \"Golden adventures\", \"Starlight dreams\", \"Your radiant birthday\"],\n        addMemory: \"➕ Add Memory\",\n        uploadImage: \"📸 Click to upload an image\",\n        uploadBtn: \"Upload\",\n        replaceBtn: \"Replace\",\n        removeImg: \"Remove\",\n        close: \"Close\"\n      },\n      hi: {\n        welcomeMsg: (name) => `✨ स्वागत है, ${name}! ✨`,\n        heroTitle: (name) => `जन्मदिन की ढेर सारी शुभकामनाएँ, ${name}!`,\n        heroSub: \"🎈 आइए इस दिन को अविस्मरणीय बनाएँ 🎈\",\n        viewMemories: \"यादें देखें\",\n        storyHeading: \"💌 एक खास संदेश\",\n        storyDefault: \"हर साल इस दिन, दुनिया थोड़ी और रोशन हो जाती है क्योंकि आपने जन्म लिया। आज हम आपका जश्न मना रहे हैं!\",\n        galleryHeading: \"📸 कीमती यादें\",\n        galleryNote: \"कुछ सबसे अनमोल पल।\",\n        wishesHeading: \"✨ जन्मदिन की शुभकामनाएँ\",\n        wishesDefault: \"आपका दिन हँसी, प्यार और ढेर सारे केक से भरा हो! 🎂✨\",\n        surpriseHeading: \"🎁 एक खास सरप्राइज़\",\n        giftMessage: \"आप सबसे अद्भुत उपहार हैं! 💖\",\n        celebrate: \"जश्न मनाएँ\",\n        memoryYears: [\"✨ 2023\", \"🌻 2024\", \"⭐️ 2025\", \"🎉 आज\"],\n        memoryCaps: [\"पहली जादुई हँसी\", \"सुनहरे सफर\", \"तारों भरे सपने\", \"आपका शानदार जन्मदिन\"],\n        addMemory: \"➕ नई याद जोड़ें\",\n        uploadImage: \"📸 तस्वीर अपलोड करें\",\n        uploadBtn: \"अपलोड करें\",\n        replaceBtn: \"बदलें\",\n        removeImg: \"हटाएँ\",\n        close: \"बंद करें\"\n      }\n    };\n\n    let currentLang = 'en';\n    let userName = \"Friend\";\n    let userData = {};\n    let memoryImages = [];\n    let cardSizes = [];\n    let currentMemories = [];\n\n    const heroTitle = document.getElementById('heroTitle');\n    const heroSub = document.getElementById('heroSub');\n    const viewMemoriesBtn = document.getElementById('viewMemoriesBtn');\n    const storyHeading = document.getElementById('storyHeading');\n    const storyText = document.getElementById('storyText');\n    const galleryHeading = document.getElementById('galleryHeading');\n    const galleryNote = document.getElementById('galleryNote');\n    const wishesHeading = document.getElementById('wishesHeading');\n    const wishesText = document.getElementById('wishesText');\n    const surpriseHeading = document.getElementById('surpriseHeading');\n    const giftMessage = document.getElementById('giftMessage');\n    const celebrateBtn = document.getElementById('celebrateBtn');\n    const welcomeMsgDiv = document.getElementById('welcomeMsg');\n    const timeline = document.getElementById('timelineContainer');\n\n    function getCurrentLang() {\n      try {\n        const urlParams = new URLSearchParams(window.location.search);\n        const urlLang = urlParams.get('lang');\n        if (urlLang === 'hi') return 'hi';\n        if (urlLang === 'en') return 'en';\n        const saved = localStorage.getItem('greeter_lang') || localStorage.getItem('customizer_lang') || 'en';\n        return saved === 'hi' ? 'hi' : 'en';\n      } catch(e) { return 'en'; }\n    }\n\n    function updateUI(lang, name) {\n      const t = translations[lang];\n      welcomeMsgDiv.innerHTML = t.welcomeMsg(name);\n      heroTitle.innerHTML = t.heroTitle(name);\n      heroSub.innerHTML = t.heroSub;\n      viewMemoriesBtn.innerHTML = `<i class=\"fas fa-images\"></i> ${t.viewMemories}`;\n      storyHeading.innerHTML = t.storyHeading;\n      galleryHeading.innerHTML = t.galleryHeading;\n      galleryNote.innerHTML = t.galleryNote;\n      wishesHeading.innerHTML = t.wishesHeading;\n      surpriseHeading.innerHTML = t.surpriseHeading;\n      giftMessage.innerHTML = t.giftMessage;\n      celebrateBtn.innerHTML = `<i class=\"fas fa-fire\"></i> ${t.celebrate}`;\n\n      const originalStory = userData.story;\n      const originalWishes = userData.wishes;\n      if (!originalStory || originalStory === translations.en.storyDefault || originalStory === translations.hi.storyDefault) {\n        storyText.innerText = t.storyDefault;\n        if (!userData.story) userData.story = t.storyDefault;\n      } else {\n        storyText.innerText = originalStory;\n      }\n      if (!originalWishes || originalWishes === translations.en.wishesDefault || originalWishes === translations.hi.wishesDefault) {\n        wishesText.innerText = t.wishesDefault;\n        if (!userData.wishes) userData.wishes = t.wishesDefault;\n      } else {\n        wishesText.innerText = originalWishes;\n      }\n    }\n\n    function updateDefaultMemoryCaptions(lang) {\n      const t = translations[lang];\n      const isDefault = currentMemories.length === 4 &&\n        (currentMemories[0].year === \"✨ 2023\" || currentMemories[0].year === \"✨ 2023\") &&\n        (currentMemories[1].year === \"🌻 2024\" || currentMemories[1].year === \"🌻 2024\") &&\n        (currentMemories[2].year === \"⭐️ 2025\" || currentMemories[2].year === \"⭐️ 2025\") &&\n        (currentMemories[3].year === \"🎉 Today\" || currentMemories[3].year === \"🎉 आज\");\n      if (isDefault) {\n        for (let i = 0; i < 4; i++) {\n          currentMemories[i].year = t.memoryYears[i];\n          currentMemories[i].caption = t.memoryCaps[i];\n        }\n        userData.memories = currentMemories;\n        localStorage.setItem('userData', JSON.stringify(userData));\n        renderTimeline();\n      }\n    }\n\n    function loadUserData() {\n      try {\n        const stored = localStorage.getItem(\"userData\");\n        userData = stored ? JSON.parse(stored) : {};\n        userName = userData.name || (currentLang === 'hi' ? \"दोस्त\" : \"Friend\");\n        if (!userData.memories || !Array.isArray(userData.memories) || userData.memories.length === 0) {\n          const t = translations[currentLang];\n          userData.memories = [\n            { year: t.memoryYears[0], caption: t.memoryCaps[0] },\n            { year: t.memoryYears[1], caption: t.memoryCaps[1] },\n            { year: t.memoryYears[2], caption: t.memoryCaps[2] },\n            { year: t.memoryYears[3], caption: t.memoryCaps[3] }\n          ];\n          localStorage.setItem('userData', JSON.stringify(userData));\n        }\n        currentMemories = [...userData.memories];\n      } catch(e) {\n        const t = translations[currentLang];\n        userData = { memories: [\n          { year: t.memoryYears[0], caption: t.memoryCaps[0] },\n          { year: t.memoryYears[1], caption: t.memoryCaps[1] },\n          { year: t.memoryYears[2], caption: t.memoryCaps[2] },\n          { year: t.memoryYears[3], caption: t.memoryCaps[3] }\n        ] };\n        userName = currentLang === 'hi' ? \"दोस्त\" : \"Friend\";\n        currentMemories = [...userData.memories];\n      }\n    }\n\n    function loadImagesAndSizes() {\n      try {\n        const storedImg = localStorage.getItem('birthday_memory_images');\n        memoryImages = storedImg ? JSON.parse(storedImg) : new Array(currentMemories.length).fill(null);\n        if (!Array.isArray(memoryImages) || memoryImages.length !== currentMemories.length) {\n          memoryImages = new Array(currentMemories.length).fill(null);\n        }\n        const storedSizes = localStorage.getItem('birthday_card_sizes');\n        cardSizes = storedSizes ? JSON.parse(storedSizes) : currentMemories.map(() => ({ width: 280, height: null }));\n        if (!Array.isArray(cardSizes) || cardSizes.length !== currentMemories.length) {\n          cardSizes = currentMemories.map(() => ({ width: 280, height: null }));\n        }\n      } catch(e) {\n        memoryImages = new Array(currentMemories.length).fill(null);\n        cardSizes = currentMemories.map(() => ({ width: 280, height: null }));\n      }\n    }\n\n    function saveAllStorage() {\n      const urlParams = new URLSearchParams(window.location.search);\n      const isEditMode = (window.self !== window.top) && (urlParams.get('mode') === 'edit');\n      if (!isEditMode) return;\n      localStorage.setItem('birthday_memory_images', JSON.stringify(memoryImages));\n      localStorage.setItem('birthday_card_sizes', JSON.stringify(cardSizes));\n      userData.memories = currentMemories;\n      localStorage.setItem('userData', JSON.stringify(userData));\n    }\n\n    // ----- Resize logic (fixed) -----\n    let activeResize = null; // { card, idx, startX, startY, startW, startH, onMove, onUp }\n\n    function startResize(e, card, idx) {\n      e.preventDefault();\n      e.stopPropagation();\n      if (activeResize) return; // already resizing\n      const startX = e.clientX;\n      const startY = e.clientY;\n      const startW = card.offsetWidth;\n      const startH = card.offsetHeight;\n      \n      function onMove(moveEvent) {\n        moveEvent.preventDefault();\n        const dx = moveEvent.clientX - startX;\n        const dy = moveEvent.clientY - startY;\n        let newW = Math.max(200, startW + dx);\n        let newH = Math.max(200, startH + dy);\n        card.style.width = newW + 'px';\n        card.style.height = newH + 'px';\n      }\n      \n      function onUp() {\n        if (activeResize) {\n          const newW = parseInt(card.style.width);\n          const newH = parseInt(card.style.height);\n          if (!isNaN(newW) && !isNaN(newH)) {\n            cardSizes[idx] = { width: newW, height: newH };\n            saveAllStorage();\n          }\n          window.removeEventListener('mousemove', activeResize.onMove);\n          window.removeEventListener('mouseup', activeResize.onUp);\n          activeResize = null;\n          document.body.style.cursor = '';\n        }\n      }\n      \n      activeResize = { card, idx, onMove, onUp };\n      window.addEventListener('mousemove', onMove);\n      window.addEventListener('mouseup', onUp);\n      document.body.style.cursor = 'nwse-resize';\n    }\n\n    // ----- Image handling -----\n    function createCardElement(mem, idx) {\n      const t = translations[currentLang];\n      const card = document.createElement('div');\n      card.className = 'memory-card';\n      card.dataset.index = idx;\n      const size = cardSizes[idx] || { width: 280, height: null };\n      card.style.width = size.width + 'px';\n      if (size.height) card.style.height = size.height + 'px';\n\n      const urlParams = new URLSearchParams(window.location.search);\n      const EDIT_MODE = (window.self !== window.top) && (urlParams.get('mode') === 'edit');\n      \n      if (EDIT_MODE) {\n        const removeBtn = document.createElement('button');\n        removeBtn.className = 'remove-card-btn';\n        removeBtn.innerHTML = '<i class=\"fas fa-times-circle\"></i>';\n        removeBtn.onclick = (e) => { e.stopPropagation(); removeCard(idx); };\n        card.appendChild(removeBtn);\n      }\n\n      const imageSlot = document.createElement('div');\n      imageSlot.className = 'image-slot';\n      \n      const img = document.createElement('img');\n      img.style.display = 'none';\n      \n      const placeholder = document.createElement('div');\n      placeholder.className = 'placeholder-text';\n      placeholder.innerHTML = `<i class=\"fas fa-camera\"></i><span>${t.uploadImage}</span>`;\n      \n      imageSlot.appendChild(placeholder);\n      imageSlot.appendChild(img);\n      card.appendChild(imageSlot);\n\n      // Set initial visibility\n      function setImage(dataUrl) {\n        if (dataUrl && dataUrl.startsWith('data:image')) {\n          img.src = dataUrl;\n          img.style.display = 'block';\n          placeholder.style.display = 'none';\n        } else {\n          img.src = '';\n          img.style.display = 'none';\n          placeholder.style.display = 'flex';\n        }\n      }\n      \n      setImage(memoryImages[idx]);\n\n      if (EDIT_MODE) {\n        const fileInput = document.createElement('input');\n        fileInput.type = 'file';\n        fileInput.accept = 'image/*';\n        fileInput.style.display = 'none';\n\n        const actionsDiv = document.createElement('div');\n        actionsDiv.className = 'image-actions';\n        const uploadBtn = document.createElement('button'); uploadBtn.className = 'img-btn'; uploadBtn.innerHTML = `<i class=\"fas fa-upload\"></i> ${t.uploadBtn}`;\n        const replaceBtn = document.createElement('button'); replaceBtn.className = 'img-btn'; replaceBtn.innerHTML = `<i class=\"fas fa-sync-alt\"></i> ${t.replaceBtn}`;\n        const removeImgBtn = document.createElement('button'); removeImgBtn.className = 'img-btn remove-btn'; removeImgBtn.innerHTML = `<i class=\"fas fa-trash-alt\"></i> ${t.removeImg}`;\n\n        function updateImage(dataUrl) {\n          memoryImages[idx] = dataUrl;\n          saveAllStorage();\n          setImage(dataUrl);\n          // Force a small delay to ensure DOM updates (especially for large images)\n          if (dataUrl && dataUrl.startsWith('data:image')) {\n            // Ensure image is fully loaded before showing (already set)\n            if (img.complete) {\n              // already loaded\n            } else {\n              img.onload = () => { img.style.display = 'block'; placeholder.style.display = 'none'; };\n            }\n          }\n          if (typeof confetti === 'function') {\n            confetti({ particleCount: 15, spread: 40 });\n          }\n        }\n\n        const handleFileSelect = (e) => {\n          const file = e.target.files[0];\n          if (file && file.type.startsWith('image/')) {\n            const reader = new FileReader();\n            reader.onload = ev => updateImage(ev.target.result);\n            reader.readAsDataURL(file);\n          }\n          fileInput.value = '';\n        };\n\n        fileInput.addEventListener('change', handleFileSelect);\n        const triggerUpload = () => fileInput.click();\n        uploadBtn.addEventListener('click', triggerUpload);\n        replaceBtn.addEventListener('click', triggerUpload);\n        removeImgBtn.addEventListener('click', () => updateImage(null));\n\n        actionsDiv.appendChild(uploadBtn);\n        actionsDiv.appendChild(replaceBtn);\n        actionsDiv.appendChild(removeImgBtn);\n        card.appendChild(actionsDiv);\n        card.appendChild(fileInput);\n      }\n\n      const yearSpan = document.createElement('div'); yearSpan.className = 'memory-year'; yearSpan.innerText = mem.year;\n      const captionSpan = document.createElement('div'); captionSpan.className = 'memory-caption'; captionSpan.innerText = mem.caption;\n      card.appendChild(yearSpan);\n      card.appendChild(captionSpan);\n\n      if (EDIT_MODE) {\n        const resizeHandle = document.createElement('div');\n        resizeHandle.className = 'resize-handle';\n        resizeHandle.innerHTML = '<i class=\"fas fa-chevron-circle-down\"></i>';\n        resizeHandle.addEventListener('mousedown', (e) => {\n          e.stopPropagation();\n          e.preventDefault();\n          startResize(e, card, idx);\n        });\n        card.appendChild(resizeHandle);\n      }\n\n      timeline.appendChild(card);\n    }\n\n    function createAddCard() {\n      const t = translations[currentLang];\n      const addCard = document.createElement('div');\n      addCard.className = 'memory-card add-card';\n      addCard.innerHTML = `\n        <div class=\"add-card-content\">\n          <i class=\"fas fa-plus-circle\"></i>\n          <span>${t.addMemory}</span>\n          <small>click to create new</small>\n        </div>\n      `;\n      addCard.addEventListener('click', addNewMemoryCard);\n      timeline.appendChild(addCard);\n    }\n\n    function removeCard(idx) {\n      if (idx >= 0 && idx < currentMemories.length) {\n        currentMemories.splice(idx, 1);\n        memoryImages.splice(idx, 1);\n        cardSizes.splice(idx, 1);\n        saveAllStorage();\n        renderTimeline();\n        applyGalleryVisibility();\n      }\n    }\n\n    function addNewMemoryCard() {\n      const t = translations[currentLang];\n      const newMem = { year: \"🆕 New\", caption: \"Click to upload\" };\n      currentMemories.push(newMem);\n      memoryImages.push(null);\n      cardSizes.push({ width: 280, height: null });\n      saveAllStorage();\n      renderTimeline();\n      setTimeout(() => {\n        if (timeline.lastChild) timeline.lastChild.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });\n      }, 100);\n    }\n\n    function renderTimeline() {\n      timeline.innerHTML = '';\n      while(memoryImages.length < currentMemories.length) memoryImages.push(null);\n      while(cardSizes.length < currentMemories.length) cardSizes.push({ width: 280, height: null });\n      currentMemories.forEach((mem, idx) => createCardElement(mem, idx));\n      const urlParams = new URLSearchParams(window.location.search);\n      const EDIT_MODE = (window.self !== window.top) && (urlParams.get('mode') === 'edit');\n      if (EDIT_MODE) createAddCard();\n    }\n\n    function applyGalleryVisibility() {\n      const gallerySection = document.getElementById('gallery');\n      if (!gallerySection) return;\n      const urlParams = new URLSearchParams(window.location.search);\n      const isPreviewMode = urlParams.get('mode') === 'preview';\n      const isInsideIframe = window.self !== window.top;\n      const EDIT_MODE = isInsideIframe && (urlParams.get('mode') === 'edit');\n      const FINAL_MODE = !isInsideIframe && !isPreviewMode;\n      if (EDIT_MODE || isPreviewMode) {\n        gallerySection.style.display = 'flex';\n      } else if (FINAL_MODE) {\n        const hasAnyImage = memoryImages.some(img => img && img.startsWith('data:image'));\n        gallerySection.style.display = hasAnyImage ? 'flex' : 'none';\n      }\n    }\n\n    function refreshLanguage() {\n      const newLang = getCurrentLang();\n      if (newLang === currentLang) return;\n      currentLang = newLang;\n      loadUserData();\n      loadImagesAndSizes();\n      updateUI(currentLang, userName);\n      updateDefaultMemoryCaptions(currentLang);\n      renderTimeline();\n      applyGalleryVisibility();\n    }\n\n    window.addEventListener('storage', function(e) {\n      if (e.key === 'greeter_lang' || e.key === 'customizer_lang' || e.key === 'userData') {\n        refreshLanguage();\n      }\n    });\n    window.addEventListener('focus', function() {\n      refreshLanguage();\n    });\n\n    currentLang = getCurrentLang();\n    loadUserData();\n    loadImagesAndSizes();\n    updateUI(currentLang, userName);\n    updateDefaultMemoryCaptions(currentLang);\n    renderTimeline();\n    applyGalleryVisibility();\n\n    document.getElementById('viewMemoriesBtn').addEventListener('click', () => {\n      document.getElementById('gallery').scrollIntoView({ behavior: 'smooth' });\n    });\n\n    const curtain = document.getElementById('curtain');\n    setTimeout(() => curtain.classList.add('open'), 500);\n    setTimeout(() => curtain.style.display = 'none', 2500);\n\n    const canvas = document.getElementById('effectsCanvas');\n    const ctx = canvas.getContext('2d');\n    let hearts = [];\n    function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }\n    resizeCanvas(); window.addEventListener('resize', resizeCanvas);\n    function createHeart() {\n      return { x: Math.random()*canvas.width, y: canvas.height+20, size: 15+Math.random()*25, speed: 1+Math.random()*3, opacity: 0.6+Math.random()*0.4, swing: Math.random()*6.28, char: ['💖','❤️','💗','💓','💕'][Math.floor(Math.random()*5)] };\n    }\n    for (let i=0; i<30; i++) hearts.push(createHeart());\n    function drawHearts() {\n      ctx.clearRect(0,0,canvas.width,canvas.height);\n      hearts.forEach(h => {\n        h.y -= h.speed;\n        h.x += Math.sin(h.swing + Date.now()*0.002)*0.5;\n        if (h.y < -50) { Object.assign(h, createHeart()); h.y = canvas.height+20; }\n        ctx.font = `${h.size}px \"Segoe UI Emoji\", \"Apple Color Emoji\", sans-serif`;\n        ctx.fillStyle = `rgba(255,100,150,${h.opacity})`;\n        ctx.fillText(h.char, h.x, h.y);\n      });\n      requestAnimationFrame(drawHearts);\n    }\n    drawHearts();\n\n    window.revealGift = () => {\n      document.getElementById('giftBox').style.display = 'none';\n      document.getElementById('giftReveal').style.display = 'block';\n      confetti({ particleCount: 150, spread: 100 });\n    };\n    window.startFireworks = () => {\n      confetti({ particleCount: 200, spread: 120 });\n      confetti({ particleCount: 200, spread: 120, origin: { x: 0.3 } });\n      confetti({ particleCount: 200, spread: 120, origin: { x: 0.7 } });\n    };\n    document.getElementById('celebrateBtn').onclick = () => window.startFireworks();\n\n    const fadeElements = document.querySelectorAll('.fade-up');\n    const observer = new IntersectionObserver(entries => {\n      entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });\n    }, { threshold: 0.2 });\n    fadeElements.forEach(el => observer.observe(el));\n\n    let heartThrottle;\n    document.addEventListener('mousemove', (e) => {\n      if (!heartThrottle) {\n        heartThrottle = setTimeout(() => {\n          const heart = document.createElement('div');\n          heart.style.cssText = `position:fixed; pointer-events:none; z-index:999; font-size:24px; left:${e.clientX}px; top:${e.clientY}px; animation:heartFloat 1.2s forwards;`;\n          heart.innerHTML = ['💖','🎂','💗'][Math.floor(Math.random()*3)];\n          document.body.appendChild(heart);\n          setTimeout(() => heart.remove(), 1200);\n          heartThrottle = null;\n        }, 40);\n      }\n    });\n    const style = document.createElement('style');\n    style.textContent = `@keyframes heartFloat{0%{opacity:1;transform:scale(0.6) translateY(0);}100%{opacity:0;transform:scale(0.3) translateY(-70px);}}`;\n    document.head.appendChild(style);\n  })();\n</script>\n\n</body></html>","config":{"activeFeatures":[["curtainReveal",true],["welcomeTyping",true]],"customData":[["curtainReveal",{"text":"","images":[],"emoji":""}],["welcomeTyping",{"text":"✨ Your Birthday Surprise Is Waiting For You ✨","images":[],"emoji":""}]],"userName":"John"}}