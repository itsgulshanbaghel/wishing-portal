{"html":"<html lang=\"en\"><head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0, user-scalable=no\">\n    <title>🎂 Birthday Bliss · Greeter.com</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&amp;family=Quicksand:wght@300;400;500;600&amp;family=Great+Vibes&amp;family=Caveat:wght@400;600;700&amp;display=swap\" rel=\"stylesheet\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --cream: #fff9f0;\n            --candle: #f7c56e;\n            --sunset: #ffb347;\n            --rose: #e86f6f;\n            --moss: #a3c9a8;\n            --lavender: #d9c8e8;\n            --warm-brown: #7a4e3a;\n            --text-dark: #4a2e2a;\n        }\n\n        body {\n            font-family: 'Quicksand', sans-serif;\n            background: var(--cream);\n            color: var(--text-dark);\n            min-height: 100vh;\n            overflow-x: hidden;\n        }\n\n        /* watercolor dreamscape */\n        body::before {\n            content: '';\n            position: fixed;\n            inset: 0;\n            background: radial-gradient(circle at 10% 20%, rgba(247, 197, 110, 0.2), transparent 60%),\n                radial-gradient(circle at 90% 70%, rgba(232, 111, 111, 0.15), transparent 65%),\n                radial-gradient(circle at 40% 80%, rgba(163, 201, 168, 0.2), transparent 50%);\n            z-index: 0;\n            pointer-events: none;\n        }\n\n        .page {\n            position: relative;\n            z-index: 5;\n            min-height: 100vh;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 60px 24px;\n            text-align: center;\n        }\n\n        /* 🎈 floating balloons & stars */\n        .float-party {\n            position: fixed;\n            inset: 0;\n            pointer-events: none;\n            z-index: 1;\n        }\n\n        .floating-item {\n            position: absolute;\n            bottom: -40px;\n            font-size: var(--size);\n            animation: floatUp linear infinite;\n            opacity: 0;\n        }\n\n        @keyframes floatUp {\n            0% {\n                transform: translateY(0) rotate(0deg);\n                opacity: 0.1;\n            }\n\n            20% {\n                opacity: 0.7;\n            }\n\n            80% {\n                opacity: 0.5;\n            }\n\n            100% {\n                transform: translateY(-120vh) rotate(12deg);\n                opacity: 0;\n            }\n        }\n\n        /* hero */\n        .hero-ornament {\n            font-family: 'Great Vibes', cursive;\n            font-size: 1.5rem;\n            color: var(--rose);\n            letter-spacing: 0.15em;\n            margin-bottom: 8px;\n        }\n\n        h1 {\n            font-family: 'Great Vibes', cursive;\n            font-size: clamp(3.8rem, 12vw, 6.2rem);\n            color: var(--warm-brown);\n            line-height: 1.2;\n        }\n\n        .cake-icon {\n            font-size: 3rem;\n            margin: 8px 0;\n            filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.1));\n        }\n\n        .name-sub {\n            font-family: 'Lora', serif;\n            font-size: clamp(1.1rem, 3vw, 1.6rem);\n            font-style: italic;\n            color: var(--rose);\n            margin-bottom: 32px;\n        }\n\n        /* flipbook */\n        .book-wrap {\n            perspective: 1200px;\n            width: min(340px, 90vw);\n            height: min(420px, 65vw);\n            max-height: 420px;\n            margin: 0 auto 32px;\n            cursor: pointer;\n        }\n\n        .book {\n            width: 100%;\n            height: 100%;\n            position: relative;\n            transform-style: preserve-3d;\n            transition: transform 0.7s cubic-bezier(0.23, 0.98, 0.32, 1);\n        }\n\n        .book.flipped {\n            transform: rotateY(-180deg);\n        }\n\n        .book-face {\n            position: absolute;\n            inset: 0;\n            backface-visibility: hidden;\n            border-radius: 6px 20px 20px 6px;\n            overflow: hidden;\n            box-shadow: 0 18px 35px rgba(122, 78, 58, 0.25), 0 0 0 1px rgba(232, 111, 111, 0.2);\n        }\n\n        .book-front {\n            background: linear-gradient(145deg, #ffe6c9 0%, #ffddb0 100%);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 32px;\n        }\n\n        .book-spine {\n            position: absolute;\n            left: 0;\n            top: 0;\n            bottom: 0;\n            width: 24px;\n            background: linear-gradient(90deg, rgba(232, 111, 111, 0.4), rgba(232, 111, 111, 0.1));\n            border-radius: 6px 0 0 6px;\n        }\n\n        .book-title {\n            font-family: 'Great Vibes', cursive;\n            font-size: 2.6rem;\n            color: var(--warm-brown);\n            margin-bottom: 12px;\n        }\n\n        .book-subtitle {\n            font-family: 'Caveat', cursive;\n            font-size: 1.1rem;\n            color: var(--rose);\n        }\n\n        .book-icon {\n            font-size: 58px;\n            margin-bottom: 12px;\n        }\n\n        .book-hint {\n            margin-top: 22px;\n            font-size: 0.7rem;\n            letter-spacing: 0.1em;\n            background: rgba(255, 245, 220, 0.7);\n            padding: 5px 12px;\n            border-radius: 40px;\n        }\n\n        .book-back {\n            background: #fffef7;\n            transform: rotateY(180deg);\n            border-radius: 20px 6px 6px 20px;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            padding: 32px 28px;\n        }\n\n        .inside-message {\n            font-family: 'Lora', serif;\n            font-style: italic;\n            font-size: 0.95rem;\n            line-height: 1.8;\n            color: var(--text-dark);\n            text-align: center;\n        }\n\n        .inside-sign {\n            font-family: 'Great Vibes', cursive;\n            font-size: 1.9rem;\n            color: var(--rose);\n            margin-top: 20px;\n        }\n\n        /* gallery strip (memories) */\n        .gallery-strip {\n            display: flex;\n            gap: 14px;\n            overflow-x: auto;\n            padding: 12px 0 24px;\n            max-width: 700px;\n            width: 100%;\n            scrollbar-width: thin;\n            scrollbar-color: var(--rose) #ffe0c4;\n        }\n\n        .gallery-strip::-webkit-scrollbar {\n            height: 5px;\n        }\n\n        .gallery-strip::-webkit-scrollbar-track {\n            background: #ffe0c4;\n            border-radius: 10px;\n        }\n\n        .gallery-strip::-webkit-scrollbar-thumb {\n            background: var(--rose);\n            border-radius: 10px;\n        }\n\n        .mem-thumb {\n            flex: 0 0 auto;\n            width: 100px;\n            height: 100px;\n            border-radius: 20px;\n            background: var(--bg, #fff0e0);\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 38px;\n            box-shadow: 0 8px 18px rgba(122, 78, 58, 0.12);\n            transition: transform 0.2s, box-shadow 0.2s;\n            cursor: pointer;\n            overflow: hidden;\n            border: 2px solid white;\n        }\n\n        .mem-thumb:hover {\n            transform: scale(1.05);\n            box-shadow: 0 12px 22px rgba(232, 111, 111, 0.2);\n        }\n\n        .mem-thumb img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n\n        /* story card */\n        .story-section {\n            background: rgba(255, 235, 215, 0.5);\n            backdrop-filter: blur(6px);\n        }\n\n        .story-card {\n            max-width: 600px;\n            width: 90%;\n            background: white;\n            border-radius: 32px;\n            padding: 40px 36px;\n            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.05);\n            border: 1px solid rgba(232, 111, 111, 0.2);\n        }\n\n        .story-top {\n            font-family: 'Great Vibes', cursive;\n            font-size: 1.8rem;\n            color: var(--rose);\n            margin-bottom: 14px;\n        }\n\n        .story-body {\n            font-family: 'Lora', serif;\n            font-style: italic;\n            font-size: 1.05rem;\n            line-height: 1.9;\n        }\n\n        /* wish & candle section */\n        .wish-section {\n            background: linear-gradient(120deg, #fff2e0, #ffead4);\n        }\n\n        .wish-card {\n            max-width: 560px;\n            width: 90%;\n            background: rgba(255, 250, 240, 0.85);\n            backdrop-filter: blur(12px);\n            border-radius: 48px;\n            padding: 40px 32px;\n            box-shadow: 0 20px 45px rgba(122, 78, 58, 0.2);\n            border: 1px solid rgba(255, 225, 190, 0.8);\n        }\n\n        .wish-emoji {\n            font-size: 68px;\n            margin-bottom: 8px;\n        }\n\n        .wish-head {\n            font-family: 'Great Vibes', cursive;\n            font-size: 2.3rem;\n            color: var(--warm-brown);\n            margin-bottom: 18px;\n        }\n\n        .wish-text {\n            font-family: 'Lora', serif;\n            font-style: italic;\n            font-size: 1.05rem;\n            line-height: 1.9;\n            margin-bottom: 32px;\n        }\n\n        .btn-celebrate {\n            padding: 14px 40px;\n            background: var(--rose);\n            border: none;\n            color: white;\n            font-family: 'Quicksand', sans-serif;\n            font-weight: 700;\n            letter-spacing: 0.1em;\n            font-size: 1rem;\n            border-radius: 60px;\n            cursor: pointer;\n            box-shadow: 0 8px 20px rgba(232, 111, 111, 0.5);\n            transition: all 0.25s;\n        }\n\n        .btn-celebrate:hover {\n            transform: translateY(-3px);\n            background: #d45a5a;\n            box-shadow: 0 14px 28px rgba(232, 111, 111, 0.6);\n        }\n\n        /* mini surprise modal */\n        .surprise-toast {\n            position: fixed;\n            bottom: 30px;\n            left: 50%;\n            transform: translateX(-50%) scale(0.9);\n            background: #fff3e6;\n            color: var(--warm-brown);\n            padding: 12px 28px;\n            border-radius: 60px;\n            font-family: 'Caveat', cursive;\n            font-size: 1.3rem;\n            font-weight: bold;\n            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);\n            z-index: 200;\n            opacity: 0;\n            transition: opacity 0.2s, transform 0.2s;\n            pointer-events: none;\n            white-space: nowrap;\n            border-left: 6px solid var(--rose);\n        }\n\n        .surprise-toast.show {\n            opacity: 1;\n            transform: translateX(-50%) scale(1);\n        }\n\n        @media (max-width: 550px) {\n            .surprise-toast {\n                font-size: 1rem;\n                white-space: normal;\n                width: 80%;\n                text-align: center;\n            }\n\n            .book-wrap {\n                margin-bottom: 20px;\n            }\n        }\n    </style>\n<style id=\"greeter-padding-style\">body { padding-bottom: 0px !important; transition: padding 0.3s; }</style><style>\n            :root {\n              --bg-primary: #f9f7ff !important;\n              --bg-secondary: #ffffff !important;\n              --text-primary: #1a1025 !important;\n              --text-secondary: #4a3b66 !important;\n              --accent-gradient: linear-gradient(145deg, #7b5df6 0%, #ff7a2f 100%) !important;\n              --accent-solid: #7b5df6 !important;\n              --card-bg: rgba(255, 255, 255, 0.75) !important;\n              --card-border: rgba(0, 0, 0, 0.05) !important;\n              --navbar-bg: rgba(255, 255, 255, 0.6) !important;\n              --shadow-sm: 0 8px 20px rgba(0, 0, 0, 0.04) !important;\n              --shadow-lg: 0 25px 40px -12px rgba(0, 0, 0, 0.12) !important;\n              --glow: rgba(123, 93, 246, 0.15) !important;\n              --mode-transition: background 0.3s ease, color 0.2s ease, border-color 0.2s !important;\n              --resizer-bg: #e0d9f0 !important;\n              --sidebar-bg: rgba(255, 255, 255, 0.5) !important;\n              --toggle-bg: #f0eaff !important;\n              --panel-bg: #f5f0ff !important;\n              --switch-bg: #d4c5f0 !important;\n              --circle-bg: #7b5df6 !important;\n            }\n          </style><link id=\"greeter-google-fonts\" rel=\"stylesheet\" href=\"https://fonts.googleapis.com/css2?family=Great+Vibes&amp;family=Poppins:wght@300;500;700&amp;display=swap\"><link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css\"><style id=\"magic-welcome-styles\">\n                    body.magic-noscroll { overflow: hidden !important; position: fixed !important; width: 100% !important; height: 100% !important; } \n                    .magic-emoji { display: inline-block; -webkit-text-fill-color: initial !important; background: none !important; color: initial !important; animation: magicHeartBeat 2s infinite; } \n                    @keyframes magicHeartBeat { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.2); } }\n                </style><style id=\"magic-gift-styles\">#gift-box-emoji { animation: giftWobble 2s infinite ease-in-out; } @keyframes giftWobble { 0%,100%{transform:rotate(0) scale(1);} 25%{transform:rotate(-8deg) scale(1.1);} 75%{transform:rotate(8deg) scale(1.1);} }</style></head>\n\n<body class=\"\" contenteditable=\"false\"><script>(function(){var lang=\"en\";localStorage.setItem(\"greeter_lang\",lang);localStorage.setItem(\"customizer_lang\",lang);var urlParams=new URLSearchParams(window.location.search);if(!urlParams.has(\"lang\")){var newUrl=window.location.href+(window.location.href.indexOf(\"?\")===-1?\"?lang=\"+lang:\"&lang=\"+lang);window.history.replaceState({},\"\",newUrl);}})();</script><script>window.addEventListener(\"load\",function(){window.scrollTo(0,0);document.documentElement.scrollTop=0;document.body.scrollTop=0;});</script>\n\n    <div class=\"float-party\" id=\"floatParty\"><div class=\"floating-item\" style=\"--size: 41.472411246719446px; left: 43.0641vw; animation-duration: 7.88934s; animation-delay: 0s;\">🌟</div><div class=\"floating-item\" style=\"--size: 44.80900985601803px; left: 46.985vw; animation-duration: 15.7158s; animation-delay: 0s;\">🎈</div><div class=\"floating-item\" style=\"--size: 28.87815170062066px; left: 10.8127vw; animation-duration: 12.8822s; animation-delay: 0s;\">🎉</div><div class=\"floating-item\" style=\"--size: 36.822631260080996px; left: 69.0894vw; animation-duration: 12.2498s; animation-delay: 0s;\">🎈</div><div class=\"floating-item\" style=\"--size: 23.039168220838313px; left: 55.6845vw; animation-duration: 14.2754s; animation-delay: 0s;\">🌟</div><div class=\"floating-item\" style=\"--size: 21.765194594377046px; left: 80.6834vw; animation-duration: 14.5889s; animation-delay: 0s;\">🎈</div><div class=\"floating-item\" style=\"--size: 30.624193493496342px; left: 95.0585vw; animation-duration: 9.90888s; animation-delay: 0s;\">💝</div><div class=\"floating-item\" style=\"--size: 28.789235695740167px; left: 85.9541vw; animation-duration: 13.6149s; animation-delay: 0s;\">🎁</div></div>\n    <div class=\"surprise-toast\" id=\"toastMsg\">🎉 Happy Birthday! 🎂</div>\n\n    <!-- hero section -->\n    <div class=\"page\" style=\"justify-content: flex-start; align-items: center; padding-top: 60px;\">\n        <div class=\"hero-ornament\">✨ another beautiful year ✨</div>\n        <h1 id=\"heroTitle\">Happy Birthday, Raman</h1>\n        <div class=\"cake-icon\">🎂🎈</div>\n        <div class=\"name-sub\" id=\"nameSub\">Raman, today is all about you ✨</div>\n\n        <!-- flipbook -->\n        <div class=\"book-wrap\">\n            <div class=\"book\" id=\"book\">\n                <div class=\"book-face book-front\">\n                    <div class=\"book-spine\"></div>\n                    <div class=\"book-icon\">🎁🎂</div>\n                    <div class=\"book-title\" id=\"bookTitle\">Birthday Wishes,<br>Raman</div>\n                    <div class=\"book-subtitle\">open for a sweet surprise</div>\n                    <div class=\"book-hint\">✨ tap to open ✨</div>\n                </div>\n                <div class=\"book-face book-back\">\n                    <div class=\"inside-message\" id=\"insideMsg\">💌 To my friend Raman, every year I watch you grow and I fall in love with you all over again. Life hasn't always been easy, but having y...</div>\n                    <div class=\"inside-sign\" id=\"insideSign\">Forever yours ♡</div>\n                </div>\n            </div>\n        </div>\n\n        <!-- memory gallery strip -->\n        <div class=\"gallery-strip\" id=\"gallery\">\n            <!-- default emoji memories will be replaced dynamically -->\n            <div class=\"mem-thumb\" style=\"--bg:#ffd9b5\">🎂</div>\n            <div class=\"mem-thumb\" style=\"--bg:#fbc8b5\">🎈</div>\n            <div class=\"mem-thumb\" style=\"--bg:#ffe0b5\">🎁</div>\n            <div class=\"mem-thumb\" style=\"--bg:#d9f0ec\">🌟</div>\n            <div class=\"mem-thumb\" style=\"--bg:#f5d0e8\">💖</div>\n            <div class=\"mem-thumb\" style=\"--bg:#c9e4de\">📸</div>\n        </div>\n    \n<style>\n.greeter-cta-section { margin: 60px auto 40px; padding: 40px 30px; max-width: 600px; text-align: center; background: rgba(255, 255, 255, 0.25); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.4); border-radius: 28px; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08); color: inherit; font-family: 'Inter', 'Quicksand', sans-serif; position: relative; z-index: 100; }\n.greeter-cta-title { font-size: 1.8rem; font-weight: 800; margin-bottom: 12px; color: inherit; line-height: 1.3; }\n.greeter-cta-desc { font-size: 1.1rem; margin-bottom: 28px; opacity: 0.9; line-height: 1.6; color: inherit; }\n.greeter-cta-btn { display: inline-block; background: linear-gradient(135deg, #ff2a5f, #ff4b2b); color: #ffffff !important; text-decoration: none; padding: 18px 36px; font-size: 1.15rem; font-weight: 700; border-radius: 50px; box-shadow: 0 10px 24px rgba(255, 42, 95, 0.4); transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.3s; border: none; cursor: pointer; text-transform: uppercase; letter-spacing: 0.5px; }\n.greeter-cta-btn:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 14px 32px rgba(255, 42, 95, 0.6); }\n.greeter-logo-accent { font-size: 2.5rem; margin-bottom: 16px; filter: drop-shadow(0 4px 8px rgba(0,0,0,0.15)); }\n@media (max-width: 600px) { .greeter-cta-section { margin: 40px 20px; padding: 30px 20px; } .greeter-cta-title { font-size: 1.5rem; } .greeter-cta-btn { padding: 15px 24px; font-size: 1rem; } }\n</style>\n<div class=\"greeter-cta-section\">\n    <div class=\"greeter-logo-accent\">✨🪄</div>\n    <h2 class=\"greeter-cta-title\" data-en=\"Create Your Own Magical Surprise\" data-hi=\"अपना जादुई सरप्राइज़ बनाएं\">Create Your Own Magical Surprise</h2>\n    <p class=\"greeter-cta-desc\" data-en=\"Surprise your loved ones with a personalized website just like this one. No coding required!\" data-hi=\"बिल्कुल इसी तरह की वेबसाइट से अपने प्रियजनों को सरप्राइज़ दें। कोई कोडिंग जरूरी नहीं!\">Surprise your loved ones with a personalized website just like this one. No coding required!</p>\n    <a href=\"/index.html\" target=\"_blank\" class=\"greeter-cta-btn\" data-en=\"Press this red button to create your own website in minutes\" data-hi=\"मिनटों में अपनी वेबसाइट बनाने के लिए यह लाल बटन दबाएं\">Press this red button to create your own website in minutes</a>\n</div>\n <script>\n(function(){\n  var lang = localStorage.getItem(\"greeter_lang\") || \"en\";\n  var section = document.querySelector(\".greeter-cta-section\");\n  if(section) {\n    var title = section.querySelector(\".greeter-cta-title\");\n    var desc = section.querySelector(\".greeter-cta-desc\");\n    var btn = section.querySelector(\".greeter-cta-btn\");\n    if(lang === \"hi\") {\n      title.innerText = title.getAttribute(\"data-hi\");\n      desc.innerText = desc.getAttribute(\"data-hi\");\n      btn.innerText = btn.getAttribute(\"data-hi\");\n    }\n  }\n})();\n</script>\n</div>\n\n    <!-- story section (personal birthday story) -->\n    <div class=\"page story-section\">\n        <div class=\"story-card\">\n            <div class=\"story-top\">💫 Our Favorite Chapter 💫</div>\n            <div class=\"story-body\" id=\"storyBody\">💌 To my friend Raman, every year I watch you grow and I fall in love with you all over again. Life hasn't always been easy, but having you by my side made every storm bearable. Today, I wish you peace, joy, and the certainty that you are never alone. Happy Birthday from the bottom of my heart. 🌹</div>\n        </div>\n    </div>\n\n    <!-- wish + celebration section -->\n    <div class=\"page wish-section\">\n        <div class=\"wish-card\">\n            <div class=\"wish-emoji\">🕯️✨</div>\n            <div class=\"wish-head\" id=\"wishHead\">Make a Wish</div>\n            <div class=\"wish-text\" id=\"wishText\">🕯️ As you blow out your candles, Raman, I'm sending you a wish for continued strength and happiness. You've overcome so much, and you shine brighter than ever. I'm proud to call you my friend. May your birthday be filled with the warmth of those who truly care. With all my love. 💫</div>\n            <button class=\"btn-celebrate\" id=\"celBtn\">🎉 Light the Candles 🕯️</button>\n        </div>\n    </div>\n\n    <script src=\"https://cdn.jsdelivr.net/npm/canvas-confetti@1\"></script>\n    <script>\n        (function () {\n            // ---------- language & userData ----------\n            function getLang() {\n                try {\n                    const urlParam = new URLSearchParams(location.search).get('lang');\n                    if (urlParam === 'hi' || urlParam === 'en') return urlParam;\n                    return localStorage.getItem('greeter_lang') || 'en';\n                } catch { return 'en'; }\n            }\n\n            const translations = {\n                en: {\n                    heroTitle: 'Happy Birthday',\n                    nameSubTemplate: '{name}, today is all about you ✨',\n                    bookTitle: 'Birthday Wishes,\\n{name}',\n                    insideMsg: 'You are a beautiful soul, and each moment with you is a gift. May your birthday sparkle with love and laughter.',\n                    insideSign: 'Forever yours ♡',\n                    storyTop: '💫 Our Favorite Chapter 💫',\n                    storyBody: 'Your birthday is the day the world received a little more magic. You bring laughter, kindness, and unforgettable memories. Here\\'s to another year of adventures together.',\n                    wishHead: 'Make a Wish',\n                    wishText: 'May your heart be full, your smile never fade, and every candle brings joy. You deserve the universe.',\n                    celebrateBtn: '🎉 Light the Candles 🕯️',\n                    toastMessage: '🎂 Happy Birthday! May all your wishes come true 🎈'\n                },\n                hi: {\n                    heroTitle: 'जन्मदिन मुबारक हो',\n                    nameSubTemplate: '{name}, आज का दिन सिर्फ तुम्हारे लिए है ✨',\n                    bookTitle: 'जन्मदिन की शुभकामनाएं,\\n{name}',\n                    insideMsg: 'तुम एक खूबसूरत रूह हो, और तुम्हारे साथ हर पल एक उपहार है। तुम्हारा जन्मदिन प्यार और हंसी से भरा हो।',\n                    insideSign: 'हमेशा तुम्हारा ♡',\n                    storyTop: '💫 हमारा प्यारा अध्याय 💫',\n                    storyBody: 'तुम्हारा जन्मदिन वह दिन है जब दुनिया को थोड़ा और जादू मिला। तुम हंसी, दया और अविस्मरणीय यादें लाते हो। एक और साल साथ बिताने के लिए शुभकामनाएं।',\n                    wishHead: 'इच्छा करो',\n                    wishText: 'तुम्हारा दिल हमेशा भरा रहे, तुम्हारी मुस्कान कभी न छीने, और हर मोमबत्ती खुशियाँ लाए। तुम ब्रह्मांड के हकदार हो।',\n                    celebrateBtn: '🎉 मोमबत्तियाँ जलाएं 🕯️',\n                    toastMessage: '🎂 जन्मदिन मुबारक! तुम्हारी सभी इच्छाएँ पूरी हों 🎈'\n                }\n            };\n\n            let lang = getLang();\n            let t = translations[lang];\n            const userData = JSON.parse(localStorage.getItem('userData') || '{}');\n            const userName = userData.name || (lang === 'hi' ? 'मेरे प्यार' : 'My Sunshine');\n            const userStory = userData.story || t.storyBody;\n            const userWish = userData.wishes || t.wishText;\n            const userMemories = userData.memories || [];\n\n            // DOM elements\n            const heroTitleEl = document.getElementById('heroTitle');\n            const nameSubEl = document.getElementById('nameSub');\n            const bookTitleEl = document.getElementById('bookTitle');\n            const insideMsgEl = document.getElementById('insideMsg');\n            const insideSignEl = document.getElementById('insideSign');\n            const storyTopEl = document.querySelector('.story-top');\n            const storyBodyEl = document.getElementById('storyBody');\n            const wishHeadEl = document.getElementById('wishHead');\n            const wishTextEl = document.getElementById('wishText');\n            const celBtn = document.getElementById('celBtn');\n            const toastMsgDiv = document.getElementById('toastMsg');\n\n            function applyLanguageAndData() {\n                t = translations[lang];\n                // hero\n                heroTitleEl.innerText = t.heroTitle + ', ' + userName;\n                nameSubEl.innerText = t.nameSubTemplate.replace('{name}', userName);\n                // book\n                bookTitleEl.innerText = t.bookTitle.replace('{name}', userName);\n                insideMsgEl.innerText = userStory.length > 40 ? userStory.substring(0, 140) : userStory;\n                insideSignEl.innerText = t.insideSign;\n                // story section\n                storyTopEl.innerText = t.storyTop;\n                storyBodyEl.innerText = userStory;\n                // wish section\n                wishHeadEl.innerText = t.wishHead;\n                wishTextEl.innerText = userWish;\n                celBtn.innerText = t.celebrateBtn;\n            }\n\n            // populate gallery from user memories or fallback\n            function loadGallery() {\n                const galleryContainer = document.getElementById('gallery');\n                if (!galleryContainer) return;\n                if (userMemories && userMemories.length > 0) {\n                    galleryContainer.innerHTML = '';\n                    userMemories.forEach(mem => {\n                        const thumb = document.createElement('div');\n                        thumb.className = 'mem-thumb';\n                        if (mem.img && mem.img.trim() !== '') {\n                            thumb.innerHTML = `<img src=\"${mem.img}\" alt=\"memory\">`;\n                        } else {\n                            thumb.innerText = mem.text || '🎈';\n                        }\n                        galleryContainer.appendChild(thumb);\n                    });\n                } else {\n                    // default fallback with birthday emojis (keep default but ensure they show)\n                    if (galleryContainer.children.length === 0 || galleryContainer.children.length < 4) {\n                        const defaultMems = ['🎂', '🎈', '🎁', '🌟', '💖', '📸'];\n                        galleryContainer.innerHTML = '';\n                        defaultMems.forEach(icon => {\n                            const div = document.createElement('div');\n                            div.className = 'mem-thumb';\n                            div.style.setProperty('--bg', '#ffe0c4');\n                            div.innerText = icon;\n                            galleryContainer.appendChild(div);\n                        });\n                    }\n                }\n            }\n\n            // ---------- floating balloons & stars (birthday vibe) ----------\n            const floatContainer = document.getElementById('floatParty');\n            const partyItems = ['🎈', '🎂', '✨', '🌟', '🎉', '💝', '🎁'];\n            function spawnFloater() {\n                const el = document.createElement('div');\n                el.className = 'floating-item';\n                const size = 18 + Math.random() * 28;\n                el.style.setProperty('--size', size + 'px');\n                el.style.left = Math.random() * 100 + 'vw';\n                el.style.animationDuration = 7 + Math.random() * 9 + 's';\n                el.style.animationDelay = '0s';\n                el.innerText = partyItems[Math.floor(Math.random() * partyItems.length)];\n                floatContainer.appendChild(el);\n                setTimeout(() => el.remove(), 12000);\n            }\n            setInterval(spawnFloater, 1400);\n\n            // book flip\n            const bookDiv = document.getElementById('book');\n            if (bookDiv) {\n                bookDiv.addEventListener('click', (e) => {\n                    e.stopPropagation();\n                    bookDiv.classList.toggle('flipped');\n                });\n            }\n\n            // confetti celebration + toast message\n            function triggerCelebration() {\n                // show toast\n                toastMsgDiv.innerText = t.toastMessage;\n                toastMsgDiv.classList.add('show');\n                setTimeout(() => toastMsgDiv.classList.remove('show'), 2800);\n                // confetti burst\n                const colors = ['#ffb347', '#e86f6f', '#f7c56e', '#a3c9a8', '#ff9f7c'];\n                for (let i = 0; i < 3; i++) {\n                    setTimeout(() => {\n                        canvasConfetti({ particleCount: 120, spread: 80, origin: { y: 0.6, x: 0.2 + i * 0.3 }, colors, angle: 70, startVelocity: 18 });\n                        canvasConfetti({ particleCount: 80, spread: 55, origin: { y: 0.5, x: 0.8 - i * 0.1 }, colors, angle: 110, startVelocity: 20 });\n                    }, i * 220);\n                }\n                canvasConfetti({ particleCount: 200, spread: 100, origin: { y: 0.4 }, colors, startVelocity: 15, ticks: 180 });\n                // extra random pops\n                setTimeout(() => {\n                    canvasConfetti({ particleCount: 300, spread: 120, origin: { y: 0.7 }, colors: ['#ffb347', '#e86f6f'], startVelocity: 12 });\n                }, 400);\n            }\n\n            if (celBtn) {\n                celBtn.addEventListener('click', triggerCelebration);\n            }\n\n            // watch for language changes (storage or focus)\n            function refreshLanguage() {\n                const newLang = getLang();\n                if (newLang !== lang) {\n                    lang = newLang;\n                    \n                    // also refresh wish text if custom wish exists, story exists\n                    const freshUserData = JSON.parse(localStorage.getItem('userData') || '{}');\n                    if (freshUserData.story) storyBodyEl.innerText = freshUserData.story;\n                    if (freshUserData.wishes) wishTextEl.innerText = freshUserData.wishes;\n                    if (freshUserData.name) {\n                        heroTitleEl.innerText = translations[lang].heroTitle + ', ' + freshUserData.name;\n                        nameSubEl.innerText = translations[lang].nameSubTemplate.replace('{name}', freshUserData.name);\n                        bookTitleEl.innerText = translations[lang].bookTitle.replace('{name}', freshUserData.name);\n                    }\n                    insideMsgEl.innerText = (freshUserData.story || translations[lang].insideMsg).substring(0, 140);\n                    toastMsgDiv.innerText = translations[lang].toastMessage;\n                }\n            }\n\n            window.addEventListener('storage', (e) => {\n                if (e.key === 'greeter_lang' || e.key === 'customizer_lang' || e.key === 'userData') {\n                    refreshLanguage();\n                    // reload gallery if memories changed\n                    const updated = JSON.parse(localStorage.getItem('userData') || '{}');\n                    if (updated.memories) {\n                        const gal = document.getElementById('gallery');\n                        if (gal) {\n                            if (updated.memories.length > 0) {\n                                gal.innerHTML = '';\n                                updated.memories.forEach(mem => {\n                                    const div = document.createElement('div');\n                                    div.className = 'mem-thumb';\n                                    if (mem.img) div.innerHTML = `<img src=\"${mem.img}\" alt=\"memory\">`;\n                                    else div.innerText = mem.text || '♡';\n                                    gal.appendChild(div);\n                                });\n                            }\n                        }\n                    }\n                }\n            });\n\n            window.addEventListener('focus', () => {\n                const newLangCheck = getLang();\n                if (newLangCheck !== lang) {\n                    lang = newLangCheck;\n                    \n                    const fresh = JSON.parse(localStorage.getItem('userData') || '{}');\n                    if (fresh.story) storyBodyEl.innerText = fresh.story;\n                    if (fresh.wishes) wishTextEl.innerText = fresh.wishes;\n                    if (fresh.memories && fresh.memories.length) {\n                        const gal = document.getElementById('gallery');\n                        if (gal) {\n                            gal.innerHTML = '';\n                            fresh.memories.forEach(mem => {\n                                const div = document.createElement('div');\n                                div.className = 'mem-thumb';\n                                if (mem.img) div.innerHTML = `<img src=\"${mem.img}\" alt=\"memory\">`;\n                                else div.innerText = mem.text || '🎈';\n                                gal.appendChild(div);\n                            });\n                        }\n                    }\n                }\n            });\n\n            // initial load of gallery and texts\n            loadGallery();\n            \n            // override story/wish from userData if present (since apply uses default story from translations but we want custom)\n            if (userStory && storyBodyEl) storyBodyEl.innerText = userStory;\n            if (userWish && wishTextEl) wishTextEl.innerText = userWish;\n            if (insideMsgEl && userStory) insideMsgEl.innerText = userStory.length > 140 ? userStory.substring(0, 137) + '...' : userStory;\n\n            // small extra: update inside sign from userData custom note? not required but nice.\n            if (userData.customNote) {\n                insideSignEl.innerText = userData.customNote;\n            }\n        })();\n    </script>\n\n\n<audio src=\"https://www.dropbox.com/scl/fi/44xjwhb6s5l9yd2q23xh2/Gift-box.mp3?rlkey=51q76p6d3juxz2o67fq0fsx2t&amp;st=ct9t6n6u&amp;dl=1\" preload=\"auto\" style=\"display: none;\"></audio></body></html>","config":{"activeFeatures":[["welcomeTyping",true],["giftBoxOpen",true],["finalSurprise",true],["scratchReveal",true]],"customData":[["welcomeTyping",{"text":"✨ A Special Surprise Is Waiting For You ✨","images":[],"emoji":"","audio":""}],["giftBoxOpen",{"text":"🎁 A special gift for you 🎁","images":[],"emoji":"","audio":""}],["finalSurprise",{"text":"You are truly one in a million! 💖","images":[],"emoji":"","audio":""}],["scratchReveal",{"text":"✨ You're a Star! ✨","images":[],"emoji":"","audio":""}]],"userName":"Raman"}}